<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style
        x:Key="AddDrinksPrimaryButtonStyle"
        BasedOn="{StaticResource TabsHeaderActionButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource PosAccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosAccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PosOnAccentForegroundBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style
        x:Key="CatalogProductButtonStyle"
        BasedOn="{StaticResource TabsHeaderActionButtonStyle}"
        TargetType="Button">
        <Setter Property="Padding" Value="8,6,8,8" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style
        x:Key="CatalogPagerButtonStyle"
        BasedOn="{StaticResource TabsHeaderActionButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style
        x:Key="TabsPagerPillButtonStyle"
        BasedOn="{StaticResource TabsHeaderActionButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="MaxHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="CartGhostButtonStyle" BasedOn="{StaticResource TabsHeaderActionButtonStyle}" TargetType="Button">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{StaticResource PosPanelMutedSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CartQtyPadButtonStyle" BasedOn="{StaticResource TabsHeaderActionButtonStyle}" TargetType="Button">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style
        x:Key="CartRemoveIconButtonStyle"
        BasedOn="{StaticResource TabsHeaderActionButtonStyle}"
        TargetType="Button">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource PosSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style
        x:Key="CatalogCategoryChipButtonStyle"
        BasedOn="{StaticResource TabsHeaderActionButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="64" />
        <Setter Property="Height" Value="64" />
        <Setter Property="MinWidth" Value="64" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="4,6" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="BorderBrush" Value="{StaticResource PosPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style
        x:Key="AddDrinksCategoryChipButtonStyle"
        BasedOn="{StaticResource CatalogCategoryChipButtonStyle}"
        TargetType="Button" />

    <Style
        x:Key="PitstopCategoryChipButtonStyle"
        BasedOn="{StaticResource CatalogCategoryChipButtonStyle}"
        TargetType="Button">
        <Setter Property="MinHeight" Value="58" />
        <Setter Property="Height" Value="58" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style
        x:Key="PitstopCatalogProductButtonStyle"
        BasedOn="{StaticResource CatalogProductButtonStyle}"
        TargetType="Button">
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style
        x:Key="PitstopPagerArrowButtonStyle"
        BasedOn="{StaticResource TabsHeaderActionButtonStyle}"
        TargetType="Button">
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource PosAccentBrush}" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

</ResourceDictionary>