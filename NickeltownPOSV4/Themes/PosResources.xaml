    <SolidColorBrush x:Key="PosWorkflowReceiveBrush" Color="#FF16A34A" />
    <SolidColorBrush x:Key="PosWorkflowCountBrush" Color="#FF7C3AED" />

    <!-- Touch numpad (theme-updated via PosThemeService) -->
    <SolidColorBrush x:Key="NumpadDigitBgBrush" Color="#FFFFFFFF" />
