    <!-- Login screen (runtime-updated via PosThemeService) -->
    <LinearGradientBrush x:Key="LoginHeroBackgroundBrush" StartPoint="0,0" EndPoint="1.15,1.2">
        <GradientStop Offset="0" Color="#FF0B1220" />
        <GradientStop Offset="0.38" Color="#FF1E3A5F" />
        <GradientStop Offset="0.72" Color="#FF312E81" />
        <GradientStop Offset="1" Color="#FF4C1D95" />
    </LinearGradientBrush>

    <Thickness x:Key="PosCardPadding">20,18</Thickness>
    <Thickness x:Key="PosPagePadding">14,12,14,12</Thickness>



    <Style x:Key="PosHeaderTextStyle" TargetType="TextBlock">

        <Setter Property="FontSize" Value="28" />

        <Setter Property="FontWeight" Value="SemiBold" />

        <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />

        <Setter Property="TextTrimming" Value="CharacterEllipsis" />

    </Style>



    <Style x:Key="PosSubheaderTextStyle" TargetType="TextBlock">

        <Setter Property="FontSize" Value="16" />

        <Setter Property="Foreground" Value="{StaticResource PosTextSecondaryBrush}" />

        <Setter Property="TextWrapping" Value="WrapWholeWords" />

    </Style>



    <Style x:Key="PosCardBorderStyle" TargetType="Border">

        <Setter Property="Padding" Value="{StaticResource PosCardPadding}" />

        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />

        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />

        <Setter Property="BorderThickness" Value="1" />

        <Setter Property="CornerRadius" Value="14" />

    </Style>

    <Style x:Key="PosHubTileButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="TabsHeaderActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PosSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="TabsHeaderSignOutStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="MinWidth" Value="104" />
        <Setter Property="Padding" Value="10,6" />
