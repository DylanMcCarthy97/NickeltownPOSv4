    <SolidColorBrush x:Key="PosSpecialPriceBrush" Color="#FFDC2626" />
    <SolidColorBrush x:Key="PosCartQtyBadgeBrush" Color="#FF2563EB" />
    <SolidColorBrush x:Key="PosProductThumbFillBrush" Color="#FFF0F3F8" />
    <SolidColorBrush x:Key="PosProductThumbBorderBrush" Color="#FFE2E8F0" />
