        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="20" />
    </Style>

    <Style x:Key="TabsHeaderIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="TabsPagerButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="68" />
        <Setter Property="MinWidth" Value="240" />
