        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="TabsPagerButtonDenseStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">
