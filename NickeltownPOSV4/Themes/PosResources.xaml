        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="SettingsSecondaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="14,8" />
