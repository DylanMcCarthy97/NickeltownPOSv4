    <!--  Modern settings shared styling  -->
    <LinearGradientBrush x:Key="SettingsHeroBrush" StartPoint="0,0" EndPoint="1,0.6">
        <GradientStop Offset="0" Color="#FF1E3A8A" />
        <GradientStop Offset="0.55" Color="#FF2563EB" />
        <GradientStop Offset="1" Color="#FF4F46E5" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SettingsHeroAccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#FF60A5FA" />
        <GradientStop Offset="1" Color="#FF818CF8" />
    </LinearGradientBrush>

