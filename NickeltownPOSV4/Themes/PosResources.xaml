        <Setter Property="BorderBrush" Value="{StaticResource PosBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20,18" />
    </Style>

    <!--  Read-only touch fields: same look as Add Funds; opens overlay keyboard / numpad on tap.  -->
    <Style x:Key="PosTouchFieldTextBoxStyle" TargetType="TextBox">
        <Setter Property="MinHeight" Value="46" />
        <Setter Property="Padding" Value="12,10" />
