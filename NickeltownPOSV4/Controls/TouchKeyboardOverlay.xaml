<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Controls.TouchKeyboardOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:LetterCaseConverter x:Key="LetterCase" />
        <SolidColorBrush x:Key="KbdKeyBgBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="KbdKeyBorderBrush" Color="#FFD6E1F5" />
        <SolidColorBrush x:Key="KbdShiftBgBrush" Color="#FFEFF5FF" />
        <SolidColorBrush x:Key="KbdBackBgBrush" Color="#FFF1F5F9" />

        <Style x:Key="KbdKeyButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource KbdKeyBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource KbdKeyBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style x:Key="KbdShiftButtonStyle" TargetType="Button" BasedOn="{StaticResource KbdKeyButtonStyle}">
            <Setter Property="Background" Value="{StaticResource KbdShiftBgBrush}" />
            <Setter Property="BorderBrush" Value="#FFBDD3FF" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="KbdBackspaceButtonStyle" TargetType="Button" BasedOn="{StaticResource KbdKeyButtonStyle}">
            <Setter Property="Background" Value="{StaticResource KbdBackBgBrush}" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="KbdSpaceButtonStyle" TargetType="Button" BasedOn="{StaticResource KbdKeyButtonStyle}">
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="KbdClearButtonStyle" TargetType="Button" BasedOn="{StaticResource KbdKeyButtonStyle}">
            <Setter Property="Background" Value="#FFFFF1F2" />
            <Setter Property="BorderBrush" Value="#55F87171" />
            <Setter Property="Foreground" Value="#FFB91C1C" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="KbdDoneButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PosAccentBrush}" />
            <Setter Property="BorderBrush" Value="#FF1E4FD6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style x:Key="KbdPreviewTextBoxStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Background" Value="#FFF8FAFF" />
            <Setter Property="BorderBrush" Value="#FFD6E3F5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#B30F172A">
        <Border
            Margin="40,0,40,14"
            Padding="16,14"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            MaxHeight="440"
            Background="#FFFAFCFF"
            BorderBrush="#FFCCDAF4"
            BorderThickness="1"
            CornerRadius="18">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="{Binding Title, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Grid.Column="1"
                        Width="40"
                        Height="40"
                        AutomationProperties.Name="Close"
                        Command="{Binding CancelCommand, Mode=OneWay}"
                        Style="{StaticResource TabsHeaderIconButtonStyle}">
                        <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="14" Glyph="&#xE711;" />
                    </Button>
                </Grid>

                <TextBox
                    Grid.Row="1"
                    Style="{StaticResource KbdPreviewTextBoxStyle}"
                    AcceptsReturn="True"
                    Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap" />

                <Grid Grid.Row="2">
                    <!-- Letter layout -->
                    <Grid
                        RowSpacing="5"
                        Visibility="{Binding IsNumbersMode, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding KeyCommand}" CommandParameter="q" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=q, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="1" Command="{Binding KeyCommand}" CommandParameter="w" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=w, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="2" Command="{Binding KeyCommand}" CommandParameter="e" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=e, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="3" Command="{Binding KeyCommand}" CommandParameter="r" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=r, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="4" Command="{Binding KeyCommand}" CommandParameter="t" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=t, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="5" Command="{Binding KeyCommand}" CommandParameter="y" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=y, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="6" Command="{Binding KeyCommand}" CommandParameter="u" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=u, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="7" Command="{Binding KeyCommand}" CommandParameter="i" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=i, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="8" Command="{Binding KeyCommand}" CommandParameter="o" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=o, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="9" Command="{Binding KeyCommand}" CommandParameter="p" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=p, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="14,0,14,0" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding KeyCommand}" CommandParameter="a" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=a, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="1" Command="{Binding KeyCommand}" CommandParameter="s" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=s, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="2" Command="{Binding KeyCommand}" CommandParameter="d" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=d, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="3" Command="{Binding KeyCommand}" CommandParameter="f" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=f, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="4" Command="{Binding KeyCommand}" CommandParameter="g" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=g, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="5" Command="{Binding KeyCommand}" CommandParameter="h" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=h, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="6" Command="{Binding KeyCommand}" CommandParameter="j" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=j, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="7" Command="{Binding KeyCommand}" CommandParameter="k" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=k, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="8" Command="{Binding KeyCommand}" CommandParameter="l" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=l, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="2" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.35*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" MinHeight="42">
                                <Button
                                    x:Name="ShiftKeyButton"
                                    AutomationProperties.Name="Shift. Hold for caps lock."
                                    Content="Shift"
                                    Style="{StaticResource KbdShiftButtonStyle}" />
                                <Border
                                    Background="#66448AFF"
                                    CornerRadius="10"
                                    IsHitTestVisible="False"
                                    Visibility="{Binding ShiftKeyHighlighted, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                            </Grid>
                            <Button Grid.Column="1" Command="{Binding KeyCommand}" CommandParameter="z" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=z, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="2" Command="{Binding KeyCommand}" CommandParameter="x" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=x, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="3" Command="{Binding KeyCommand}" CommandParameter="c" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=c, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="4" Command="{Binding KeyCommand}" CommandParameter="v" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=v, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="5" Command="{Binding KeyCommand}" CommandParameter="b" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=b, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="6" Command="{Binding KeyCommand}" CommandParameter="n" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=n, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="7" Command="{Binding KeyCommand}" CommandParameter="m" Content="{Binding UppercaseLabels, Converter={StaticResource LetterCase}, ConverterParameter=m, Mode=OneWay}" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button
                                Grid.Column="8"
                                Command="{Binding BackspaceCommand}"
                                Content="⌫"
                                Style="{StaticResource KbdBackspaceButtonStyle}"
                                ToolTipService.ToolTip="Backspace" />
                        </Grid>
                    </Grid>

                    <!-- Numbers / symbols -->
                    <Grid
                        RowSpacing="5"
                        Visibility="{Binding IsNumbersMode, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding DigitCommand}" CommandParameter="1" Content="1" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="1" Command="{Binding DigitCommand}" CommandParameter="2" Content="2" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="2" Command="{Binding DigitCommand}" CommandParameter="3" Content="3" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="3" Command="{Binding DigitCommand}" CommandParameter="4" Content="4" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="4" Command="{Binding DigitCommand}" CommandParameter="5" Content="5" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="5" Command="{Binding DigitCommand}" CommandParameter="6" Content="6" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="6" Command="{Binding DigitCommand}" CommandParameter="7" Content="7" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="7" Command="{Binding DigitCommand}" CommandParameter="8" Content="8" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="8" Command="{Binding DigitCommand}" CommandParameter="9" Content="9" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="9" Command="{Binding DigitCommand}" CommandParameter="0" Content="0" Style="{StaticResource KbdKeyButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="1" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding DigitCommand}" CommandParameter="-" Content="-" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="1" Command="{Binding DigitCommand}" CommandParameter="/" Content="/" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="2" Command="{Binding DigitCommand}" CommandParameter=":" Content=":" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="3" Command="{Binding DigitCommand}" CommandParameter=";" Content=";" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="4" Command="{Binding DigitCommand}" CommandParameter="&#x2C;" Content="&#x2C;" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="5" Command="{Binding DigitCommand}" CommandParameter="(" Content="(" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button Grid.Column="6" Command="{Binding DigitCommand}" CommandParameter=")" Content=")" Style="{StaticResource KbdKeyButtonStyle}" />
                            <Button
                                Grid.Column="7"
                                Command="{Binding BackspaceCommand}"
                                Content="⌫"
                                Style="{StaticResource KbdBackspaceButtonStyle}"
                                ToolTipService.ToolTip="Backspace" />
                        </Grid>
                    </Grid>
                </Grid>

                <Grid Grid.Row="3" ColumnSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="2.85*" />
                        <ColumnDefinition Width="0.55*" />
                        <ColumnDefinition Width="0.55*" />
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        Command="{Binding ToggleNumbersLayoutCommand}"
                        Content="{Binding NumbersToggleButtonLabel, Mode=OneWay}"
                        Style="{StaticResource KbdKeyButtonStyle}" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding SpaceCommand}"
                        Content="Space"
                        Style="{StaticResource KbdSpaceButtonStyle}" />
                    <Button Grid.Column="2" Command="{Binding CommaCommand}" Content="&#x2C;" Style="{StaticResource KbdKeyButtonStyle}" />
                    <Button Grid.Column="3" Command="{Binding DotCommand}" Content="." Style="{StaticResource KbdKeyButtonStyle}" />
                    <Button Grid.Column="4" Command="{Binding ClearCommand}" Content="Clear" Style="{StaticResource KbdClearButtonStyle}" />
                    <Button Grid.Column="5" Command="{Binding DoneCommand}" Content="Done" Style="{StaticResource KbdDoneButtonStyle}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
