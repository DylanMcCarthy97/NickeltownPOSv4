<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Controls.LoginPinPad"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Padding="2,0,2,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 1 2 3 -->
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="1"
                Content="1"
                Style="{StaticResource LoginDigitButtonStyle}" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="2"
                Content="2"
                Style="{StaticResource LoginDigitButtonStyle}" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="3"
                Content="3"
                Style="{StaticResource LoginDigitButtonStyle}" />

            <!-- 4 5 6 -->
            <Button
                Grid.Row="1"
                Grid.Column="0"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="4"
                Content="4"
                Style="{StaticResource LoginDigitButtonStyle}" />
            <Button
                Grid.Row="1"
                Grid.Column="1"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="5"
                Content="5"
                Style="{StaticResource LoginDigitButtonStyle}" />
            <Button
                Grid.Row="1"
                Grid.Column="2"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="6"
                Content="6"
                Style="{StaticResource LoginDigitButtonStyle}" />

            <!-- 7 8 9 -->
            <Button
                Grid.Row="2"
                Grid.Column="0"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="7"
                Content="7"
                Style="{StaticResource LoginDigitButtonStyle}" />
            <Button
                Grid.Row="2"
                Grid.Column="1"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="8"
                Content="8"
                Style="{StaticResource LoginDigitButtonStyle}" />
            <Button
                Grid.Row="2"
                Grid.Column="2"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="9"
                Content="9"
                Style="{StaticResource LoginDigitButtonStyle}" />

            <!-- Backspace | 0 | Clear -->
            <Button
                Grid.Row="3"
                Grid.Column="0"
                Command="{Binding NumpadBackspaceCommand}"
                Style="{StaticResource LoginDigitButtonStyle}">
                <FontIcon
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="18"
                    Glyph="&#xE750;" />
            </Button>
            <Button
                Grid.Row="3"
                Grid.Column="1"
                Command="{Binding NumpadDigitCommand}"
                CommandParameter="0"
                Content="0"
                Style="{StaticResource LoginDigitButtonStyle}" />
            <Button
                Grid.Row="3"
                Grid.Column="2"
                Command="{Binding NumpadClearCommand}"
                Content="Clear"
                Style="{StaticResource LoginClearButtonStyle}" />
        </Grid>
    </Border>
</UserControl>
