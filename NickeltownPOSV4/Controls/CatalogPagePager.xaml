<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Controls.CatalogPagePager"
    x:Name="PagerRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Border
        Height="40"
        Padding="4,2"
        HorizontalAlignment="Center"
        Background="{StaticResource PosSurfaceBrush}"
        BorderBrush="{StaticResource PosBorderBrush}"
        BorderThickness="1"
        CornerRadius="16"
        Visibility="{Binding ShowPager, ElementName=PagerRoot, Converter={StaticResource BoolToVis}, Mode=OneWay}">
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Button
                Command="{Binding PreviousCommand, ElementName=PagerRoot}"
                IsEnabled="{Binding IsPreviousEnabled, ElementName=PagerRoot, Mode=OneWay}"
                Style="{StaticResource TabsPagerPillButtonStyle}"
                ToolTipService.ToolTip="Previous page">
                <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="14" Glyph="&#xE72B;" />
            </Button>
            <TextBlock
                MinWidth="96"
                Padding="4,0"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{StaticResource PosTextPrimaryBrush}"
                Text="{Binding PageLabel, ElementName=PagerRoot, Mode=OneWay}"
                TextAlignment="Center" />
            <Button
                Command="{Binding NextCommand, ElementName=PagerRoot}"
                IsEnabled="{Binding IsNextEnabled, ElementName=PagerRoot, Mode=OneWay}"
                Style="{StaticResource TabsPagerPillButtonStyle}"
                ToolTipService.ToolTip="Next page">
                <FontIcon FontFamily="Segoe MDL2 Assets" FontSize="14" Glyph="&#xE72A;" />
            </Button>
        </StackPanel>
    </Border>
</UserControl>