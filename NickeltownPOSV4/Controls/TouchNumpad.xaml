<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Controls.TouchNumpad"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="NumpadDigitButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource NumpadDigitBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource NumpadDigitBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style x:Key="NumpadSecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource NumpadActionBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource NumpadDigitBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style x:Key="NumpadClearButtonStyle" TargetType="Button" BasedOn="{StaticResource NumpadSecondaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource NumpadClearBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource NumpadClearBorderBrush}" />
            <Setter Property="Foreground" Value="{StaticResource NumpadClearFgBrush}" />
        </Style>
    </UserControl.Resources>

    <Border
        Padding="8,6"
        HorizontalAlignment="Stretch"
        Background="{StaticResource NumpadShellBgBrush}"
        BorderBrush="{StaticResource NumpadShellBorderBrush}"
        BorderThickness="1"
        CornerRadius="14">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Command="{Binding NumpadDigitCommand}" CommandParameter="7" Content="7" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="0" Grid.Column="1" Command="{Binding NumpadDigitCommand}" CommandParameter="8" Content="8" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="0" Grid.Column="2" Command="{Binding NumpadDigitCommand}" CommandParameter="9" Content="9" Style="{StaticResource NumpadDigitButtonStyle}" />

            <Button Grid.Row="1" Grid.Column="0" Command="{Binding NumpadDigitCommand}" CommandParameter="4" Content="4" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="1" Grid.Column="1" Command="{Binding NumpadDigitCommand}" CommandParameter="5" Content="5" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="1" Grid.Column="2" Command="{Binding NumpadDigitCommand}" CommandParameter="6" Content="6" Style="{StaticResource NumpadDigitButtonStyle}" />

            <Button Grid.Row="2" Grid.Column="0" Command="{Binding NumpadDigitCommand}" CommandParameter="1" Content="1" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="2" Grid.Column="1" Command="{Binding NumpadDigitCommand}" CommandParameter="2" Content="2" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="2" Grid.Column="2" Command="{Binding NumpadDigitCommand}" CommandParameter="3" Content="3" Style="{StaticResource NumpadDigitButtonStyle}" />

            <Button Grid.Row="3" Grid.Column="0" Command="{Binding NumpadDigitCommand}" CommandParameter="00" Content="00" FontSize="18" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="3" Grid.Column="1" Command="{Binding NumpadDigitCommand}" CommandParameter="0" Content="0" Style="{StaticResource NumpadDigitButtonStyle}" />
            <Button Grid.Row="3" Grid.Column="2" Command="{Binding NumpadDigitCommand}" CommandParameter="." Content="." Style="{StaticResource NumpadDigitButtonStyle}" />

            <Grid Grid.Row="4" Grid.ColumnSpan="3" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{Binding NumpadBackspaceCommand}" Content="Backspace" Style="{StaticResource NumpadSecondaryButtonStyle}" />
                <Button Grid.Column="1" Command="{Binding NumpadClearCommand}" Content="Clear" Style="{StaticResource NumpadClearButtonStyle}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>