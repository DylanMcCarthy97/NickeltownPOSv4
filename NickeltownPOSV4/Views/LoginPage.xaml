<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NickeltownPOSV4.Controls"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Width="1024" Height="768" Background="{StaticResource LoginHeroBackgroundBrush}">
        <!-- Hero background -->

        <!-- Soft light orbs -->
        <Ellipse
            Width="520"
            Height="520"
            Margin="-180,-120,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Fill="#22FFFFFF"
            IsHitTestVisible="False"
            Opacity="0.55" />
        <Ellipse
            Width="380"
            Height="380"
            Margin="0,0,-120,80"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Fill="#18FDE68A"
            IsHitTestVisible="False"
            Opacity="0.35" />
        <Ellipse
            Width="280"
            Height="280"
            Margin="0,-40,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Fill="#1493C5FD"
            IsHitTestVisible="False"
            Opacity="0.4" />

        <!-- Card shadow -->
        <Border
            Width="596"
            Padding="0,14,14,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#40000000"
            CornerRadius="30"
            IsHitTestVisible="False" />

        <Border
            MaxWidth="592"
            Padding="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="28">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#55FFFFFF" />
                    <GradientStop Offset="1" Color="#18FFFFFF" />
                </LinearGradientBrush>
            </Border.Background>
            <Border
                Padding="36,32,36,24"
                CornerRadius="26"
                Translation="0,0,28"
                Background="#FFF9FAFB"
                IsHitTestVisible="True">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel>
                    <Border
                        Padding="16,12"
                        HorizontalAlignment="Center"
                        Background="#FFFFFFFF"
                        BorderBrush="#140F172A"
                        BorderThickness="1"
                        CornerRadius="20">
                        <Image
                            MaxWidth="400"
                            MaxHeight="108"
                            HorizontalAlignment="Center"
                            Stretch="Uniform"
                            Source="ms-appx:///Assets/FlounderersLogo.png" />
                    </Border>

                    <TextBlock
                        Margin="0,22,0,0"
                        HorizontalAlignment="Center"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="#FF0F172A"
                        Text="Nickeltown POS"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />

                    <TextBlock
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        FontSize="13"
                        FontWeight="SemiBold"
                        CharacterSpacing="100"
                        Foreground="#FF64748B"
                        Text="TEAM SIGN IN"
                        TextAlignment="Center" />

                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="#FF475569"
                        Text="Enter your 4-digit PIN — signs in automatically"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />

                    <Border
                        Margin="0,22,0,0"
                        Padding="18,14"
                        HorizontalAlignment="Center"
                        Background="#FFFFFFFF"
                        BorderBrush="#1A0F172A"
                        BorderThickness="1"
                        CornerRadius="999">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <Grid Width="24" Height="24" Margin="0,0,18,0">
                                <Ellipse
                                    Width="24"
                                    Height="24"
                                    Fill="#FFF1F5F9"
                                    Stroke="#330F172A"
                                    StrokeThickness="1.5" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Fill="{StaticResource PosAccentBrush}"
                                    Visibility="{Binding Dot0Filled, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                            </Grid>
                            <Grid Width="24" Height="24" Margin="0,0,18,0">
                                <Ellipse
                                    Width="24"
                                    Height="24"
                                    Fill="#FFF1F5F9"
                                    Stroke="#330F172A"
                                    StrokeThickness="1.5" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Fill="{StaticResource PosAccentBrush}"
                                    Visibility="{Binding Dot1Filled, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                            </Grid>
                            <Grid Width="24" Height="24" Margin="0,0,18,0">
                                <Ellipse
                                    Width="24"
                                    Height="24"
                                    Fill="#FFF1F5F9"
                                    Stroke="#330F172A"
                                    StrokeThickness="1.5" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Fill="{StaticResource PosAccentBrush}"
                                    Visibility="{Binding Dot2Filled, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                            </Grid>
                            <Grid Width="24" Height="24">
                                <Ellipse
                                    Width="24"
                                    Height="24"
                                    Fill="#FFF1F5F9"
                                    Stroke="#330F172A"
                                    StrokeThickness="1.5" />
                                <Ellipse
                                    Width="12"
                                    Height="12"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Fill="{StaticResource PosAccentBrush}"
                                    Visibility="{Binding Dot3Filled, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border
                        Height="44"
                        Margin="0,10,0,0"
                        Padding="10,8"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Background="#14DC2626"
                        BorderBrush="#40DC2626"
                        BorderThickness="1"
                        CornerRadius="14"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <FontIcon
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="{StaticResource PosBalanceNegativeBrush}"
                                Glyph="&#xE783;" />
                            <TextBlock
                                MaxWidth="480"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#FFB91C1C"
                                Text="{Binding StatusMessage, Mode=OneWay}"
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <controls:LoginPinPad Margin="0,10,0,0" IsEnabled="{Binding CanEnterDigits, Mode=OneWay}" />

                    <ProgressRing
                        Width="36"
                        Height="36"
                        Margin="0,14,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource PosAccentBrush}"
                        IsActive="{Binding IsBusy, Mode=OneWay}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Border>

        <Button
            Width="116"
            Height="42"
            Margin="0,14,16,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Click="CloseApp_Click"
            Style="{StaticResource TabsHeaderActionButtonStyle}"
            ToolTipService.ToolTip="Close Nickeltown POS">
            <StackPanel Orientation="Horizontal">
                <FontIcon
                    Margin="0,0,7,0"
                    VerticalAlignment="Center"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="14"
                    Glyph="&#xE7E8;" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Text="Close App" />
            </StackPanel>
        </Button>
    </Grid>
</Page>
