<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:controls="using:NickeltownPOSV4.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Required">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="SettingsGeneralTileStyle" TargetType="Button" BasedOn="{StaticResource PosHubTileButtonStyle}" />
    </Page.Resources>

    <Grid Padding="{StaticResource PosPagePadding}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:PosPageHero
            Grid.Row="0"
            IconGlyph="&#xE713;"
            Subtitle="Sign out or exit. Use the bottom bar for Tabs, Pitstop, and other modes. Admin tools are under Admin; reports under Reports."
            Title="Settings" />

        <Grid
            Grid.Row="1"
            ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                AutomationProperties.Name="Logout"
                Command="{Binding LogoutCommand}"
                Style="{StaticResource SettingsGeneralTileStyle}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Border
                        Width="72"
                        Height="72"
                        Background="{StaticResource SettingsHeroAccentBrush}"
                        CornerRadius="20">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="34"
                            Foreground="#FFFFFFFF"
                            Glyph="&#xE748;" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="Logout" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Sign out current user"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="1"
                AutomationProperties.Name="Appearances"
                Command="{Binding AppearanceCommand}"
                Style="{StaticResource SettingsGeneralTileStyle}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Border
                        Width="72"
                        Height="72"
                        Background="{StaticResource PosAccentBrush}"
                        CornerRadius="20">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="34"
                            Foreground="#FFFFFFFF"
                            Glyph="&#xE790;" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="Appearances" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Colour themes"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Button>

            <Button
                Grid.Column="2"
                AutomationProperties.Name="Exit"
                Command="{Binding ExitCommand}"
                Style="{StaticResource SettingsGeneralTileStyle}">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Border
                        Width="72"
                        Height="72"
                        Background="{StaticResource PosBalanceNegativeBrush}"
                        CornerRadius="20">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="34"
                            Foreground="#FFFFFFFF"
                            Glyph="&#xE8BB;" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="Exit" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Exit application"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
