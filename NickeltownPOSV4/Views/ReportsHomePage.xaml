<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.ReportsHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NickeltownPOSV4.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Required">

    <Page.Resources>
        <Style x:Key="ReportsTileButtonStyle" TargetType="Button" BasedOn="{StaticResource PosHubTileButtonStyle}">
            <Setter Property="MinHeight" Value="200" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>
    </Page.Resources>

    <Grid Padding="{StaticResource PosPagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:PosPageHero
            Grid.Row="0"
            IconGlyph="&#xE9F9;"
            Subtitle="Monthly bar tabs PDFs, stock snapshots, and raw CSV exports. Files save under Documents\POS Reports and open automatically."
            Title="Reports" />

        <Grid Grid.Row="1" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button
                Grid.Row="0"
                VerticalAlignment="Stretch"
                Command="{Binding OpenPitstopEndOfDayCommand}"
                Style="{StaticResource ReportsTileButtonStyle}">
                <StackPanel Spacing="10" VerticalAlignment="Center">
                    <FontIcon
                        HorizontalAlignment="Left"
                        FontSize="32"
                        Foreground="{StaticResource PosAccentBrush}"
                        Glyph="&#xE8A5;" />
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="Pitstop end-of-day" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Pitstop terminal cash-up only (bar tabs excluded): Square batch, outside merch and raffle, prizes, and PDF."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Button>
            <Button
                Grid.Row="1"
                VerticalAlignment="Stretch"
                Command="{Binding OpenExportsCommand}"
                Style="{StaticResource ReportsTileButtonStyle}">
                <StackPanel Spacing="10" VerticalAlignment="Center">
                    <FontIcon
                        HorizontalAlignment="Left"
                        FontSize="32"
                        Foreground="{StaticResource PosAccentBrush}"
                        Glyph="&#xE74C;" />
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="Monthly &amp; stock exports" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Build monthly bar tabs PDFs, stock snapshot PDFs, email them, or export the raw monthly activity CSV."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
