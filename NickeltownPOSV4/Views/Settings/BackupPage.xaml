<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.Settings.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="14,12,14,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,14" Style="{StaticResource SettingsPageHeroStyle}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="56"
                    Height="56"
                    VerticalAlignment="Center"
                    Background="{StaticResource SettingsHeroAccentBrush}"
                    CornerRadius="16">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        Foreground="#FFFFFFFF"
                        Glyph="&#xE74E;" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="Backup now" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Style="{StaticResource SettingsHeroSubtitleStyle}"
                        Text="Creates a timestamped zip containing the SQLite database (VACUUM INTO snapshot, safe under WAL)."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Margin="0,12,0,0"
            Padding="14,12"
            Background="{StaticResource PosSurfaceBrush}"
            BorderBrush="{StaticResource PosBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <StackPanel>
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PosTextSecondaryBrush}"
                    Text="Source database" />
                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="13"
                    Foreground="{StaticResource PosTextPrimaryBrush}"
                    IsTextSelectionEnabled="True"
                    Text="{Binding DatabaseFilePath, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="10">
            <Button
                MinHeight="56"
                HorizontalAlignment="Stretch"
                Command="{Binding CreateBackupCommand}"
                Content="Pick folder &amp; back up now"
                FontSize="16"
                FontWeight="SemiBold"
                Style="{StaticResource TabsPagerButtonStyle}" />

            <Border
                Padding="12,10"
                Background="{StaticResource PosSurfaceAltBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding LastBackupPath, Converter={StaticResource BoolToVis}, ConverterParameter=NotEmpty, Mode=OneWay}">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Last backup" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="13"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        IsTextSelectionEnabled="True"
                        Text="{Binding LastBackupPath, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <TextBlock
                FontSize="12"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="{Binding StatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Button
            Grid.Row="3"
            MinHeight="44"
            Margin="0,12,0,0"
            HorizontalAlignment="Left"
            Command="{Binding BackToSettingsCommand}"
            Content="Back to settings"
            Style="{StaticResource TabsHeaderActionButtonStyle}" />
    </Grid>
</Page>
