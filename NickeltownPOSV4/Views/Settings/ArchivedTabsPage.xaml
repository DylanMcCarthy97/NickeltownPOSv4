<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.Settings.ArchivedTabsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="14,12,14,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Hero header with refresh action  -->
        <Border Grid.Row="0" Style="{StaticResource SettingsPageHeroStyle}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="52"
                    Height="52"
                    Background="{StaticResource SettingsHeroAccentBrush}"
                    CornerRadius="14">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Foreground="#FFFFFFFF"
                        Glyph="&#xE7B8;" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="Archived tabs" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Style="{StaticResource SettingsHeroSubtitleStyle}"
                        Text="Closed and archived tabs across both member and guest workflows." />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SettingsPrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Foreground="#FFFFFFFF" Glyph="&#xE72C;" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  Paginated list, no scrolling  -->
        <Border Grid.Row="1" Style="{StaticResource SettingsCardStyle}">
            <Grid RowSpacing="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsRepeater Grid.Row="0" ItemsSource="{Binding Rows.CurrentPageItems, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Padding="12,10"
                                Background="{StaticResource SettingsCardElevatedBgBrush}"
                                BorderBrush="{StaticResource SettingsCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource PosTextPrimaryBrush}"
                                            Text="{Binding DisplayName, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{StaticResource PosTextSecondaryBrush}">
                                            <Run Text="{Binding TabType, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding LastActivityText, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding StatusText, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource PosTextPrimaryBrush}"
                                        Text="{Binding BalanceText, Mode=OneWay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!--  Empty state  -->
                <TextBlock
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="{StaticResource PosTextSecondaryBrush}"
                    Text="No archived or closed tabs yet."
                    Visibility="{Binding Rows.IsEmpty, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
            </Grid>
        </Border>

        <!--  Page indicator + Prev/Next  -->
        <Grid Grid.Row="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="{Binding Rows.RangeIndicator, Mode=OneWay}" />
            <Button
                Grid.Column="1"
                Command="{Binding Rows.PreviousPageCommand}"
                Style="{StaticResource SettingsPagerButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontSize="12" Glyph="&#xE76B;" />
                    <TextBlock Text="Prev" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="2"
                Command="{Binding Rows.NextPageCommand}"
                Style="{StaticResource SettingsPagerButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Next" />
                    <FontIcon FontSize="12" Glyph="&#xE76C;" />
                </StackPanel>
            </Button>
        </Grid>

        <TextBlock
            Grid.Row="3"
            FontSize="12"
            Foreground="{StaticResource PosTextSecondaryBrush}"
            Text="{Binding StatusMessage, Mode=OneWay}"
            TextWrapping="WrapWholeWords" />

        <Button
            Grid.Row="4"
            HorizontalAlignment="Left"
            Command="{Binding BackToSettingsCommand}"
            Content="Back to settings"
            Style="{StaticResource SettingsSecondaryButtonStyle}" />
    </Grid>
</Page>
