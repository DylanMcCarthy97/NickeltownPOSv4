<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.Settings.UserManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="14,12,14,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Hero header with primary actions  -->
        <Border Grid.Row="0" Style="{StaticResource SettingsPageHeroStyle}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="52"
                    Height="52"
                    Background="{StaticResource SettingsHeroAccentBrush}"
                    CornerRadius="14">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Foreground="#FFFFFFFF"
                        Glyph="&#xE716;" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="User management" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Style="{StaticResource SettingsHeroSubtitleStyle}"
                        Text="Add, edit, deactivate staff and reset PINs. PINs are used directly by the POS login screen." />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SettingsSecondaryButtonStyle}"
                    Visibility="{Binding IsListVisible, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Command="{Binding OpenAddCommand}"
                    Style="{StaticResource SettingsPrimaryButtonStyle}"
                    Visibility="{Binding IsListVisible, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Foreground="#FFFFFFFF" Glyph="&#xE710;" />
                        <TextBlock Text="Add user" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!--  Paginated staff list (list + pager inside the same card)  -->
        <Border
            Grid.Row="1"
            Style="{StaticResource SettingsCardStyle}"
            Visibility="{Binding IsListVisible, Converter={StaticResource BoolToVis}, Mode=OneWay}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer
                    Grid.Row="0"
                    HorizontalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <ItemsRepeater ItemsSource="{Binding Staff.CurrentPageItems, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="12,8"
                                        Background="{StaticResource SettingsCardElevatedBgBrush}"
                                        BorderBrush="{StaticResource SettingsCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                                    Text="{Binding DisplayName, Mode=OneWay}" />
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                                    Text="{Binding SubtitleText, Mode=OneWay}" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                                <Button
                                                    Click="OnEditUserClicked"
                                                    Content="Edit"
                                                    Style="{StaticResource SettingsSecondaryButtonStyle}"
                                                    Tag="{Binding Id}" />
                                                <Button
                                                    Click="OnResetPinClicked"
                                                    Content="Reset PIN"
                                                    Style="{StaticResource SettingsSecondaryButtonStyle}"
                                                    Tag="{Binding Id}" />
                                                <Button
                                                    Click="OnDeactivateClicked"
                                                    Content="Deactivate"
                                                    Style="{StaticResource SettingsSecondaryButtonStyle}"
                                                    Tag="{Binding Id}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{StaticResource PosTextSecondaryBrush}"
                            Text="No staff yet — tap &#x201C;Add user&#x201D; to create the first account."
                            Visibility="{Binding Staff.IsEmpty, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                    </Grid>
                </ScrollViewer>

                <!--  Pager footer inside the list card so it never collides with the bottom nav  -->
                <Grid
                    Grid.Row="1"
                    ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="{Binding Staff.RangeIndicator, Mode=OneWay}" />
                    <Button
                        Grid.Column="1"
                        Command="{Binding Staff.PreviousPageCommand}"
                        Style="{StaticResource SettingsPagerButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="12" Glyph="&#xE76B;" />
                            <TextBlock Text="Prev" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="2"
                        Command="{Binding Staff.NextPageCommand}"
                        Style="{StaticResource SettingsPagerButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Next" />
                            <FontIcon FontSize="12" Glyph="&#xE76C;" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!--  Inline editor (Add / Edit / Reset PIN)  -->
        <Border
            Grid.Row="1"
            Style="{StaticResource SettingsCardStyle}"
            Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVis}, Mode=OneWay}">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PosTextPrimaryBrush}"
                    Text="{Binding EditorTitle, Mode=OneWay}" />

                <Grid Grid.Row="1" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="14">
                        <StackPanel Spacing="6" Visibility="{Binding EditorShowsNameAndRole, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="DISPLAY NAME" />
                            <Button Command="{Binding EditDisplayNameCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                                <TextBlock Text="{Binding EditorDisplayNameSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                            </Button>
                        </StackPanel>

                        <StackPanel Spacing="6" Visibility="{Binding EditorShowsNameAndRole, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="ROLE" />
                            <Button Command="{Binding ToggleRoleCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                                <TextBlock Text="{Binding EditorRoleSummary, Mode=OneWay}" />
                            </Button>
                        </StackPanel>

                        <StackPanel Spacing="6" Visibility="{Binding EditorShowsActiveToggle, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="ACTIVE" />
                            <ToggleSwitch
                                IsOn="{Binding EditorIsActive, Mode=TwoWay}"
                                OffContent="Inactive"
                                OnContent="Active" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="14">
                        <StackPanel Spacing="6" Visibility="{Binding EditorShowsPin, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="4-DIGIT PIN" />
                            <Button Command="{Binding EditPinCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                                <TextBlock Text="{Binding EditorPinSummary, Mode=OneWay}" />
                            </Button>
                            <TextBlock
                                FontSize="11"
                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                Text="This PIN is used directly by the POS login screen. Duplicates are blocked so sign-in stays unambiguous."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Command="{Binding CancelEditorCommand}"
                        Content="Cancel"
                        Style="{StaticResource SettingsSecondaryButtonStyle}" />
                    <Button
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SaveEditorCommand}"
                        Content="Save"
                        Style="{StaticResource SettingsPrimaryButtonStyle}" />
                </Grid>
            </Grid>
        </Border>

        <!--  Compact footer: Back-to-settings on left, status message on right  -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                Command="{Binding BackToSettingsCommand}"
                Content="Back to settings"
                Style="{StaticResource SettingsSecondaryButtonStyle}" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="{Binding StatusMessage, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
        </Grid>
    </Grid>
</Page>
