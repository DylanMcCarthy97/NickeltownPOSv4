<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.Membership.MembershipApplicationsPage"
    x:Name="ApplicationsRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NickeltownPOSV4.Controls"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="14,12,14,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsPageHeroStyle}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="52"
                    Height="52"
                    Background="{StaticResource SettingsHeroAccentBrush}"
                    CornerRadius="14">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Foreground="#FFFFFFFF"
                        Glyph="&#xE7C3;" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="Applications" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Style="{StaticResource SettingsHeroSubtitleStyle}"
                        Text="Submitted membership applications awaiting committee review." />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Command="{Binding NewPaperApplicationCommand}"
                    Style="{StaticResource SettingsPrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Foreground="#FFFFFFFF" Glyph="&#xE710;" />
                        <TextBlock Text="New paper application" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SettingsCardStyle}">
            <Grid>
                <ScrollViewer
                    HorizontalScrollMode="Disabled"
                    Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}, Mode=OneWay}"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="6">
                        <Grid Padding="4,0" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="0.7*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="APP #" />
                            <TextBlock Grid.Column="1" Style="{StaticResource SettingsFieldLabelStyle}" Text="APPLICANT" />
                            <TextBlock Grid.Column="2" Style="{StaticResource SettingsFieldLabelStyle}" Text="SOURCE" />
                            <TextBlock Grid.Column="3" Style="{StaticResource SettingsFieldLabelStyle}" Text="STATUS" />
                            <TextBlock Grid.Column="4" Style="{StaticResource SettingsFieldLabelStyle}" Text="SUBMITTED" />
                            <TextBlock Grid.Column="5" Style="{StaticResource SettingsFieldLabelStyle}" Text="PHONE" />
                            <TextBlock Grid.Column="6" Style="{StaticResource SettingsFieldLabelStyle}" Text="EMAIL" />
                            <TextBlock Grid.Column="7" Style="{StaticResource SettingsFieldLabelStyle}" Text="VEHICLE" />
                            <TextBlock Grid.Column="8" Style="{StaticResource SettingsFieldLabelStyle}" Text="ACTIONS" />
                        </Grid>

                        <ItemsRepeater ItemsSource="{Binding Items, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="10,8"
                                        Background="{StaticResource SettingsCardElevatedBgBrush}"
                                        BorderBrush="{StaticResource SettingsCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="1.3*" />
                                                <ColumnDefinition Width="0.7*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                                Text="{Binding ApplicationNumber, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                                Text="{Binding ApplicantName, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="2"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding SourceText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="3"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource PosAccentBrush}"
                                                Text="{Binding StatusText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="4"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding SubmittedText, Mode=OneWay}" />
                                            <TextBlock
                                                Grid.Column="5"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding Phone, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="6"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding Email, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Grid.Column="7"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding VehicleRegistration, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                            <StackPanel
                                                Grid.Column="8"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                                <Button
                                                    Command="{Binding ElementName=ApplicationsRoot, Path=DataContext.ViewCommand}"
                                                    CommandParameter="{Binding}"
                                                    Content="View"
                                                    Style="{StaticResource SettingsSecondaryButtonStyle}" />
                                                <Button
                                                    Command="{Binding ElementName=ApplicationsRoot, Path=DataContext.EditCommand}"
                                                    CommandParameter="{Binding}"
                                                    Content="Edit"
                                                    Style="{StaticResource SettingsSecondaryButtonStyle}"
                                                    Visibility="{Binding CanEdit, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                                                <Button
                                                    Command="{Binding ElementName=ApplicationsRoot, Path=DataContext.DeleteCommand}"
                                                    CommandParameter="{Binding}"
                                                    Content="Delete"
                                                    Style="{StaticResource SettingsSecondaryButtonStyle}"
                                                    Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}, Mode=OneWay, ConverterParameter=Invert}">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="28"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Glyph="&#xE7C3;" />
                    <TextBlock
                        FontSize="15"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="No applications yet"
                        TextAlignment="Center" />
                    <TextBlock
                        MaxWidth="360"
                        FontSize="13"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Tap New Paper Application to enter a membership form received on paper."
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock
            Grid.Row="2"
            FontSize="12"
            Foreground="{StaticResource PosTextSecondaryBrush}"
            Text="{Binding StatusMessage, Mode=OneWay}"
            TextWrapping="WrapWholeWords" />

        <Button
            Grid.Row="3"
            HorizontalAlignment="Left"
            Command="{Binding BackToMembershipHomeCommand}"
            Content="Back to memberships"
            Style="{StaticResource SettingsSecondaryButtonStyle}" />
    </Grid>
</Page>
