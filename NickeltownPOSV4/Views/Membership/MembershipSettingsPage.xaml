<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.Membership.MembershipSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Grid Padding="14,12,14,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsPageHeroStyle}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="52" Height="52" Background="{StaticResource SettingsHeroAccentBrush}" CornerRadius="14">
                    <FontIcon HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Foreground="#FFFFFFFF" Glyph="&#xE713;" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="Membership settings" />
                    <TextBlock Margin="0,2,0,0" Style="{StaticResource SettingsHeroSubtitleStyle}" Text="Fees, membership year, reminder days, committee email, and club contact details." />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PosTextPrimaryBrush}" Text="Membership year &amp; fees" />

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="MEMBERSHIP YEAR" />
                        <Button Command="{Binding EditMembershipYearLabelCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding MembershipYearLabel, Mode=OneWay}" />
                        </Button>
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="3">
                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="YEAR STARTS" />
                            <Button Command="{Binding EditMembershipYearStartCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                                <TextBlock Text="{Binding MembershipYearStartText, Mode=OneWay}" />
                            </Button>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="YEAR ENDS" />
                            <Button Command="{Binding EditMembershipYearEndCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                                <TextBlock Text="{Binding MembershipYearEndText, Mode=OneWay}" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="JOINING FEE (JUL–DEC)" />
                        <Button Command="{Binding EditJoiningFeeFullCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding JoiningFeeFullText, Mode=OneWay}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="JOINING FEE (JAN–JUN)" />
                        <Button Command="{Binding EditJoiningFeeHalfCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding JoiningFeeHalfText, Mode=OneWay}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="RENEWAL FEE" />
                        <Button Command="{Binding EditRenewalFeeCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding RenewalFeeText, Mode=OneWay}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="REMINDER DAYS BEFORE EXPIRY" />
                        <Button Command="{Binding EditReminderDaysCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding ReminderDaysText, Mode=OneWay}" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PosTextPrimaryBrush}" Text="Club contact details" />

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="COMMITTEE EMAIL" />
                        <Button Command="{Binding EditCommitteeEmailCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding CommitteeEmailSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="CLUB NAME" />
                        <Button Command="{Binding EditClubNameCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding ClubNameSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="ABN" />
                        <Button Command="{Binding EditClubAbnCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding ClubAbnSummary, Mode=OneWay}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="PO BOX" />
                        <Button Command="{Binding EditClubPoBoxCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding ClubPoBoxSummary, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="PHONE" />
                        <Button Command="{Binding EditClubPhoneCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding ClubPhoneSummary, Mode=OneWay}" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="EMAIL" />
                        <Button Command="{Binding EditClubEmailCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding ClubEmailSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="3">
                        <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="LOGO PATH" />
                        <Button Command="{Binding EditLogoPathCommand}" Style="{StaticResource SettingsTapFieldStyle}">
                            <TextBlock Text="{Binding LogoPathSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        </Button>
                    </StackPanel>
                </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Button
            Grid.Row="2"
            MinHeight="48"
            HorizontalAlignment="Stretch"
            Command="{Binding SaveCommand}"
            Content="Save membership settings"
            Style="{StaticResource SettingsPrimaryButtonStyle}" />

        <TextBlock
            Grid.Row="3"
            FontSize="12"
            Foreground="{StaticResource PosTextSecondaryBrush}"
            Text="{Binding StatusMessage, Mode=OneWay}"
            TextWrapping="WrapWholeWords" />

        <Button
            Grid.Row="4"
            HorizontalAlignment="Left"
            Command="{Binding BackToMembershipHomeCommand}"
            Content="Back to memberships"
            Style="{StaticResource SettingsSecondaryButtonStyle}" />
    </Grid>
</Page>
