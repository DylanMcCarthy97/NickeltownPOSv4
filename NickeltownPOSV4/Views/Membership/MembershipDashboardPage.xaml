<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.Membership.MembershipDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NickeltownPOSV4.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Grid Padding="14,12,14,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:PosPageHero
            Grid.Row="0"
            IconGlyph="&#xE9D2;"
            Subtitle="Current membership year summary and workload at a glance."
            Title="Membership dashboard" />

        <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="MEMBERSHIP YEAR" />
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PosTextPrimaryBrush}" Text="{Binding MembershipYearLabel, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="TOTAL APPLICATIONS" />
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PosTextPrimaryBrush}" Text="{Binding TotalApplicationsText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="PENDING REVIEW" />
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PosTextPrimaryBrush}" Text="{Binding PendingApplicationsText, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="ACTIVE MEMBERS" />
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PosTextPrimaryBrush}" Text="{Binding ActiveMembersText, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource SettingsCardStyle}">
            <StackPanel Spacing="4">
                <TextBlock FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="RENEWALS DUE" />
                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PosTextPrimaryBrush}" Text="{Binding RenewalsDueText, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Spacing="8">
            <TextBlock FontSize="12" Foreground="{StaticResource PosTextSecondaryBrush}" Text="{Binding StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            <Button HorizontalAlignment="Left" Command="{Binding BackToMembershipHomeCommand}" Content="Back to memberships" Style="{StaticResource SettingsSecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>
