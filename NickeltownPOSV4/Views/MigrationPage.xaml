<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.MigrationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    RequestedTheme="Light">

    <Page.Resources>
        <conv:MigrationWizardStepForegroundConverter x:Key="StepFg" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:MigrationValidationSeverityToBrushConverter x:Key="SeverityFg" />
        <conv:MigrationDiagnosticRowBrushConverter x:Key="MigDiagBrush" />
    </Page.Resources>

    <Grid Padding="14,12,14,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,14" Style="{StaticResource SettingsPageHeroStyle}">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    MinWidth="92"
                    MinHeight="48"
                    VerticalAlignment="Center"
                    Padding="14,10"
                    Click="Back_Click"
                    Content="Back"
                    Foreground="#FFFFFFFF"
                    Style="{StaticResource TabsHeaderActionButtonStyle}" />
                <Border
                    Grid.Column="1"
                    Width="56"
                    Height="56"
                    VerticalAlignment="Center"
                    Background="{StaticResource SettingsHeroAccentBrush}"
                    CornerRadius="16">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        Foreground="#FFFFFFFF"
                        Glyph="&#xE896;" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="Legacy data import" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Style="{StaticResource SettingsHeroSubtitleStyle}"
                        Text="Import Nickeltown v2 JSON into SQLite: pick a folder, validate, backup originals, then import."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Margin="0,0,0,0"
            Padding="4,6"
            Background="{StaticResource PosSurfaceBrush}"
            BorderBrush="{StaticResource PosBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Text="1 Folder"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{Binding Step, Converter={StaticResource StepFg}, ConverterParameter=SelectV2Folder, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Text="2 Detect"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{Binding Step, Converter={StaticResource StepFg}, ConverterParameter=DetectJsonFiles, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Text="3 Preview"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{Binding Step, Converter={StaticResource StepFg}, ConverterParameter=PreviewCounts, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Text="4 Validate"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{Binding Step, Converter={StaticResource StepFg}, ConverterParameter=ValidateData, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Text="5 Backup"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{Binding Step, Converter={StaticResource StepFg}, ConverterParameter=BackupOriginals, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Text="6 Import"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{Binding Step, Converter={StaticResource StepFg}, ConverterParameter=ImportToSqlite, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Text="7 Summary"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    Foreground="{Binding Step, Converter={StaticResource StepFg}, ConverterParameter=Summary, Mode=OneWay}" />
            </Grid>
        </Border>

        <TextBlock
            Grid.Row="2"
            Margin="0,6,0,0"
            MaxHeight="40"
            FontSize="12"
            Foreground="{StaticResource PosTextPrimaryBrush}"
            Text="{Binding StatusMessage, Mode=OneWay}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="WrapWholeWords"
            LineHeight="18" />

        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="204" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="8,6"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Actions" />
                        <Button
                            Margin="0,8,0,0"
                            MinHeight="42"
                            Padding="8,6"
                            Content="1. Folder"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            Command="{Binding PickFolderCommand}" />
                        <Button
                            Margin="0,6,0,0"
                            MinHeight="42"
                            Padding="8,6"
                            Content="2. Detect"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            Command="{Binding DetectCommand}" />
                        <Button
                            Margin="0,6,0,0"
                            MinHeight="42"
                            Padding="8,6"
                            Content="3. Preview"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            Command="{Binding BuildPreviewCommand}" />
                        <Button
                            Margin="0,6,0,0"
                            MinHeight="42"
                            Padding="8,6"
                            Content="4. Validate"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            Command="{Binding ValidateCommand}" />
                        <Button
                            Margin="0,6,0,0"
                            MinHeight="42"
                            Padding="8,6"
                            Content="5. Backup"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            Command="{Binding BackupCommand}" />
                        <Button
                            Margin="0,6,0,0"
                            MinHeight="42"
                            Padding="8,6"
                            Content="6. Import"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            Command="{Binding ImportCommand}"
                            ToolTipService.ToolTip="Writes to local SQLite. Duplicate file imports are skipped when fingerprints match." />
                        <Button
                            Margin="0,6,0,0"
                            MinHeight="42"
                            Padding="8,6"
                            Content="7. Summary"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            Command="{Binding BuildSummaryCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="84" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontSize="12"
                    Foreground="{StaticResource PosTextSecondaryBrush}"
                    Text="{Binding SelectedFolder, Mode=OneWay, TargetNullValue='No folder'}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

                <Border
                    Grid.Row="1"
                    Margin="0,6,0,0"
                    Padding="8,6"
                    Background="{StaticResource PosSurfaceAltBrush}"
                    BorderBrush="{StaticResource PosBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Detected" />
                            <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding DetectedFiles, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,4"
                                            Padding="0,0,0,4"
                                            BorderBrush="{StaticResource PosBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="96" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="72" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Kind, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Margin="8,0,8,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                                    Text="{Binding RelativePath, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                                    Text="{Binding LengthBytes, Mode=OneWay}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border
                    Grid.Row="2"
                    Margin="0,6,0,0"
                    Padding="8,6"
                    Background="{StaticResource PosSurfaceAltBrush}"
                    BorderBrush="{StaticResource PosBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="56" />
                            </Grid.ColumnDefinitions>

                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Preview" />
                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                Text="#" />

                            <TextBlock Grid.Row="1" FontSize="12" Text="Drinks" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.Drinks, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="2" FontSize="12" Text="Items" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.Items, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="3" FontSize="12" Text="Categories" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.Categories, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="4" FontSize="12" Text="Tabs" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.Tabs, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="5" FontSize="12" Text="Tab hist." />
                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.TabHistoryEntries, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="6" FontSize="12" Text="Members" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.Members, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="7" FontSize="12" Text="Bartenders" />
                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.Bartenders, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="8" FontSize="12" Text="Pitstop" />
                            <TextBlock
                                Grid.Row="8"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.PitstopSales, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="9" FontSize="12" Text="Square" />
                            <TextBlock
                                Grid.Row="9"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.SquareConfigRoots, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="10" FontSize="12" Text="Settings" />
                            <TextBlock
                                Grid.Row="10"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.SettingsDocuments, Mode=OneWay, FallbackValue=-}" />

                            <TextBlock Grid.Row="11" FontSize="12" Text="Unread (tabular)" />
                            <TextBlock
                                Grid.Row="11"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding Preview.UnreadableOrMalformedFiles, Mode=OneWay, FallbackValue=-}" />
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Border
                    Grid.Row="3"
                    Margin="0,6,0,0"
                    Padding="8,6"
                    Background="{StaticResource PosSurfaceAltBrush}"
                    BorderBrush="{StaticResource PosBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="Diagnostics"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Row="1"
                            Margin="0,4,0,6"
                            FontSize="11"
                            Foreground="{StaticResource PosTextSecondaryBrush}"
                            Text="Red=tabular unreadable · Amber=warning"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PreviewDiagnostics, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,6"
                                            Padding="8,6"
                                            Background="{Binding Converter={StaticResource MigDiagBrush}, ConverterParameter=Background}"
                                            BorderBrush="{Binding Converter={StaticResource MigDiagBrush}, ConverterParameter=Border}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.ColumnSpan="2"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                                    Text="{Binding FileName, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />

                                                <TextBlock
                                                    Grid.Row="1"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                                    Text="Kind" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    FontSize="12"
                                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                                    Text="{Binding FileKind, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />

                                                <TextBlock
                                                    Grid.Row="2"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                                    Text="Root" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    FontSize="12"
                                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                                    Text="{Binding RootJsonType, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />

                                                <TextBlock
                                                    Grid.Row="3"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                                    Text="Match" />
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                                    MaxLines="2"
                                                    Text="{Binding MatchedCollectionPath, Mode=OneWay, TargetNullValue=-}"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="WrapWholeWords" />

                                                <TextBlock
                                                    Grid.Row="4"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                                    Text="Cnt · U" />
                                                <StackPanel
                                                    Grid.Row="4"
                                                    Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    Orientation="Horizontal">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding RecordCount, Mode=OneWay}" />
                                                    <TextBlock
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="{StaticResource PosTextSecondaryBrush}"
                                                        Text="·" />
                                                    <TextBlock
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding CountedAsUnreadableImportFailure, Mode=OneWay}" />
                                                </StackPanel>

                                                <TextBlock
                                                    Grid.Row="5"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,4,0,0"
                                                    FontSize="11"
                                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                                    Text="{Binding RelativePath, Mode=OneWay}"
                                                    TextTrimming="CharacterEllipsis" />

                                                <TextBlock
                                                    Grid.Row="6"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,4,0,0"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                                    Text="{Binding ParseError, Mode=OneWay}"
                                                    TextWrapping="WrapWholeWords"
                                                    Visibility="{Binding ParseError, Converter={StaticResource NullToVis}, Mode=OneWay}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="4" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="8,6"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Validation" />
                        <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding ValidationIssues, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,6"
                                        Padding="0,0,0,6"
                                        BorderBrush="{StaticResource PosBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="{Binding Severity, Converter={StaticResource SeverityFg}, Mode=OneWay}"
                                                Text="{Binding Severity, Mode=OneWay}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="13"
                                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                                Text="{Binding Message, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding SourceFile, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border
                Grid.Column="2"
                Padding="8,6"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding Summary, Converter={StaticResource NullToVis}, Mode=OneWay}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Summary" />
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource PosTextSecondaryBrush}" Text="In: " />
                            <TextBlock VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="{Binding Summary.TotalImported, Mode=OneWay}" />
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource PosTextSecondaryBrush}" Text="Skip: " />
                            <TextBlock VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="{Binding Summary.TotalSkippedDuplicate, Mode=OneWay}" />
                            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource PosTextSecondaryBrush}" Text="Fail: " />
                            <TextBlock VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PosBalanceNegativeBrush}" Text="{Binding Summary.TotalFailedRecords, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="Backup" />
                        <TextBlock FontSize="11" Foreground="{StaticResource PosTextPrimaryBrush}" Text="{Binding Summary.BackupFolder, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="Log" />
                        <TextBlock FontSize="11" Foreground="{StaticResource PosTextPrimaryBrush}" Text="{Binding Summary.LogFilePath, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                        <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="Notes" />
                        <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding Summary.Highlights, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,4" FontSize="11" Text="{Binding}" TextWrapping="WrapWholeWords" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock
                            Margin="0,14,0,0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PosTextPrimaryBrush}"
                            Text="SQLite verification"
                            Visibility="{Binding ImportVerification, Converter={StaticResource NullToVis}, Mode=OneWay}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="11"
                            Foreground="{StaticResource PosTextSecondaryBrush}"
                            Text="Current database totals after this run (open vs archived tabs, history lines, etc.)."
                            TextWrapping="WrapWholeWords"
                            Visibility="{Binding ImportVerification, Converter={StaticResource NullToVis}, Mode=OneWay}" />
                        <Grid
                            Margin="0,8,0,0"
                            Visibility="{Binding ImportVerification, Converter={StaticResource NullToVis}, Mode=OneWay}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" MinWidth="48" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" FontSize="12" Text="Open tabs" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.TabsOpenCount, Mode=OneWay}" />
                            <TextBlock Grid.Row="1" FontSize="12" Text="Archived tabs" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.TabsArchivedCount, Mode=OneWay}" />
                            <TextBlock Grid.Row="2" FontSize="12" Text="Tab entries / history" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.TabEntriesCount, Mode=OneWay}" />
                            <TextBlock Grid.Row="3" FontSize="12" Text="Items (stock rows)" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.ItemsCount, Mode=OneWay}" />
                            <TextBlock Grid.Row="4" FontSize="12" Text="Bartenders" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.BartendersCount, Mode=OneWay}" />
                            <TextBlock Grid.Row="5" FontSize="12" Text="Members" />
                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.MembersCount, Mode=OneWay}" />
                            <TextBlock Grid.Row="6" FontSize="12" Text="Pitstop sales" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.PitstopSalesCount, Mode=OneWay}" />
                            <TextBlock Grid.Row="7" Margin="0,8,0,0" FontSize="12" Text="This run — records imported" />
                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="1"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.RunRecordsImported, Mode=OneWay}" />
                            <TextBlock Grid.Row="8" FontSize="12" Text="This run — files skipped (duplicate)" />
                            <TextBlock
                                Grid.Row="8"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Text="{Binding ImportVerification.RunFilesSkippedDuplicate, Mode=OneWay}" />
                            <TextBlock Grid.Row="9" FontSize="12" Text="This run — failed records" />
                            <TextBlock
                                Grid.Row="9"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PosBalanceNegativeBrush}"
                                Text="{Binding ImportVerification.RunFailedRecords, Mode=OneWay}" />
                            <TextBlock
                                Grid.Row="10"
                                Grid.ColumnSpan="2"
                                Margin="0,8,0,0"
                                FontSize="11"
                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                Text="Re-importing the same LegacyId updates rows; unchanged files are skipped via fingerprint. Synthetic LegacyIds stay stable when the export omits Id."
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <TextBlock
                            Margin="0,12,0,0"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Sample tabs (SQLite, up to 5)"
                            Visibility="{Binding ImportVerification, Converter={StaticResource NullToVis}, Mode=OneWay}" />
                        <ItemsControl
                            Margin="0,6,0,0"
                            ItemsSource="{Binding ImportVerification.SampleTabs, Mode=OneWay}"
                            Visibility="{Binding ImportVerification, Converter={StaticResource NullToVis}, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="8,6"
                                        Background="{StaticResource PosSurfaceAltBrush}"
                                        BorderBrush="{StaticResource PosBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding TabName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,4,0,0" FontSize="13" Text="{Binding BalanceText, Mode=OneWay}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding LastActivity, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding MemberAndStatusLine, Mode=OneWay}" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding LegacyLine, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock
                            Margin="0,12,0,0"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Sample items (SQLite, up to 5)"
                            Visibility="{Binding ImportVerification, Converter={StaticResource NullToVis}, Mode=OneWay}" />
                        <ItemsControl
                            Margin="0,6,0,0"
                            ItemsSource="{Binding ImportVerification.SampleItems, Mode=OneWay}"
                            Visibility="{Binding ImportVerification, Converter={StaticResource NullToVis}, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="8,6"
                                        Background="{StaticResource PosSurfaceAltBrush}"
                                        BorderBrush="{StaticResource PosBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="12"
                                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                                Text="{Binding DetailLine, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
