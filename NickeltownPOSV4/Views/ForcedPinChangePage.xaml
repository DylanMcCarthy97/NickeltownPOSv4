<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.ForcedPinChangePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NickeltownPOSV4.Controls"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Width="1024" Height="768" Background="{StaticResource PosCanvasBrush}">
        <Border
            MaxWidth="560"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource PosSurfaceBrush}"
            BorderBrush="{StaticResource PosBorderBrush}"
            BorderThickness="1"
            CornerRadius="20">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Text="Set a new PIN" />
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="15"
                    Foreground="{StaticResource PosTextSecondaryBrush}"
                    Text="This account still uses the default PIN. Choose a new 4-digit PIN before continuing."
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="14"
                    Foreground="{StaticResource PosTextSecondaryBrush}"
                    Text="{Binding StepHint, Mode=OneWay}" />
                <controls:LoginPinPad Margin="0,0,0,12" IsEnabled="{Binding CanEnterDigits, Mode=OneWay}" />
                <TextBlock
                    FontSize="14"
                    Foreground="#FFB91C1C"
                    Text="{Binding StatusMessage, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
