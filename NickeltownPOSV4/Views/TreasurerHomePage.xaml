<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.TreasurerHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Required">

    <Grid Padding="12,10,12,10" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsPageHeroStyle}">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="Treasurer" />
                <TextBlock
                    Style="{StaticResource SettingsHeroSubtitleStyle}"
                    Text="Accounts, transactions, bank import, reconciliation, and reports (ported from POSBar V2)."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <TabView
            x:Name="TreasurerTabs"
            Grid.Row="1"
            TabWidthMode="Equal"
            CanDragTabs="False"
            CanReorderTabs="False"
            SelectionChanged="TreasurerTabs_SelectionChanged">
            <TabViewItem Header="Dashboard" Tag="dashboard">
                <ScrollViewer Padding="8">
                    <StackPanel x:Name="DashboardPanel" Spacing="8" />
                </ScrollViewer>
            </TabViewItem>
            <TabViewItem Header="Transactions" Tag="transactions">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="AddTransaction_Click" Content="Add" Style="{StaticResource TabsHeaderActionButtonStyle}" />
                        <Button Click="RefreshTransactions_Click" Content="Refresh" Style="{StaticResource TabsHeaderActionButtonStyle}" />
                    </StackPanel>
                    <ListView
                        x:Name="TransactionsList"
                        Grid.Row="1"
                        SelectionMode="Single"
                        DoubleTapped="TransactionsList_DoubleTapped" />
                </Grid>
            </TabViewItem>
            <TabViewItem Header="Uncategorised" Tag="uncat">
                <ListView x:Name="UncategorisedList" />
            </TabViewItem>
            <TabViewItem Header="Accounts" Tag="accounts">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button Click="AddAccount_Click" Content="Add account" Style="{StaticResource TabsHeaderActionButtonStyle}" />
                    <ListView x:Name="AccountsList" Grid.Row="1" DoubleTapped="AccountsList_DoubleTapped" />
                </Grid>
            </TabViewItem>
            <TabViewItem Header="Categories" Tag="categories">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button Click="AddCategory_Click" Content="Add category" Style="{StaticResource TabsHeaderActionButtonStyle}" />
                    <ListView x:Name="CategoriesList" Grid.Row="1" />
                </Grid>
            </TabViewItem>
            <TabViewItem Header="Reports" Tag="reports">
                <StackPanel Padding="8" Spacing="10">
                    <Button
                        MinHeight="48"
                        Click="ExportTreasurerReport_Click"
                        Content="Export treasurer PDF to Documents\POS Reports"
                        Style="{StaticResource TabsHeaderActionButtonStyle}" />
                    <TextBlock
                        x:Name="ReportsStatusText"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </TabViewItem>
            <TabViewItem Header="Audit" Tag="audit">
                <ListView x:Name="AuditList" />
            </TabViewItem>
            <TabViewItem Header="Reconciliation" Tag="recon">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="ImportBankCsv_Click" Content="Import bank CSV" Style="{StaticResource TabsHeaderActionButtonStyle}" />
                        <Button Click="RefreshReconciliation_Click" Content="Refresh" Style="{StaticResource TabsHeaderActionButtonStyle}" />
                    </StackPanel>
                    <ListView x:Name="ReconciliationList" Grid.Row="1" />
                </Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>
