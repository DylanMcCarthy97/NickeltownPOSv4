<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Views.Panels.ArchivedTabsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:vm="using:NickeltownPOSV4.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ArchivedEraseButtonStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ArchivedEraseDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ArchivedEraseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PosButtonDangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PosButtonDangerBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PosOnAccentForegroundBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid Padding="0">
        <Grid Padding="12,10" Visibility="{Binding EraseOverlayVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="280" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PosTextPrimaryBrush}"
                    Text="Archived tabs" />
                <Button
                    Grid.Column="1"
                    MinWidth="72"
                    MinHeight="36"
                    Command="{Binding CloseCommand}"
                    Content="Close"
                    Style="{StaticResource TabsHeaderActionButtonStyle}" />
            </Grid>
            <TextBlock
                Grid.Row="1"
                Margin="0,6,0,0"
                FontSize="13"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="{Binding PageLabel, Mode=OneWay}" />
            <TextBlock
                Grid.Row="2"
                Margin="0,6,0,0"
                FontSize="12"
                Foreground="{StaticResource PosBalanceNegativeBrush}"
                Text="{Binding StatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords"
                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
            <ListView
                Grid.Row="3"
                Margin="0,8,0,0"
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding Items, Mode=OneWay}"
                SelectedItem="{Binding Selected, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ArchivedTabRowViewModel">
                        <Grid Padding="4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                    Text="{x:Bind DisplayLabel, Mode=OneTime}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="12"
                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                    Text="{x:Bind LastActivityText, Mode=OneTime}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                Text="{x:Bind BalanceLine, Mode=OneTime}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel
                Grid.Row="4"
                Margin="0,8,0,0"
                Orientation="Horizontal">
                <Button
                    MinWidth="100"
                    MinHeight="40"
                    Margin="0,0,6,0"
                    Command="{Binding PreviousPageCommand}"
                    Content="Prev"
                    Style="{StaticResource TabsHeaderActionButtonStyle}" />
                <Button
                    MinWidth="100"
                    MinHeight="40"
                    Margin="0,0,6,0"
                    Command="{Binding NextPageCommand}"
                    Content="Next"
                    Style="{StaticResource TabsHeaderActionButtonStyle}" />
                <Button
                    MinWidth="88"
                    MinHeight="40"
                    Margin="0,0,6,0"
                    Command="{Binding RefreshCommand}"
                    Content="Refresh"
                    Style="{StaticResource TabsHeaderActionButtonStyle}" />
            </StackPanel>
            <StackPanel
                Grid.Row="5"
                Margin="0,8,0,0"
                Orientation="Horizontal">
                <Button
                    MinWidth="120"
                    MinHeight="44"
                    Margin="0,0,6,0"
                    Command="{Binding RestoreCommand}"
                    Content="Restore"
                    Style="{StaticResource TabsPagerButtonStyle}"
                    Visibility="{Binding CanRestore, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                <Button
                    MinWidth="120"
                    MinHeight="44"
                    Command="{Binding PermanentDeleteCommand}"
                    Content="Erase…"
                    Style="{StaticResource TabsPagerButtonStyle}"
                    Visibility="{Binding CanPermanentDelete, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <Grid Background="#990F172A" Visibility="{Binding EraseOverlayVisible, Converter={StaticResource BoolToVis}, Mode=OneWay}">
            <Border
                Width="360"
                Padding="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel>
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="Confirm permanent erase"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontSize="13"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="{Binding EraseCaption, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <Grid Margin="0,14,0,0" ColumnDefinitions="*,10,*">
                        <Button
                            Grid.Column="0"
                            Command="{Binding CancelEraseCommand}"
                            Content="Cancel"
                            Style="{StaticResource ArchivedEraseButtonStyle}" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding ConfirmEraseCommand}"
                            Content="Erase"
                            Style="{StaticResource ArchivedEraseDangerButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
