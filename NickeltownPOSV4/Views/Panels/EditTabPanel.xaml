<?xml version="1.0" encoding="utf-8"?>

<UserControl

    x:Class="NickeltownPOSV4.Views.Panels.EditTabPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:conv="using:NickeltownPOSV4.Converters"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <SolidColorBrush x:Key="TapFieldBgBrush" Color="#FFF8FAFF" />

        <SolidColorBrush x:Key="TapFieldBorderBrush" Color="#FFD6E3F5" />

        <Style x:Key="EditTabTapFieldStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">

            <Setter Property="MinHeight" Value="48" />

            <Setter Property="HorizontalAlignment" Value="Stretch" />

            <Setter Property="HorizontalContentAlignment" Value="Left" />

            <Setter Property="Padding" Value="12,10" />

            <Setter Property="Background" Value="{StaticResource TapFieldBgBrush}" />

            <Setter Property="BorderBrush" Value="{StaticResource TapFieldBorderBrush}" />

            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="CornerRadius" Value="10" />

            <Setter Property="FontWeight" Value="SemiBold" />

            <Setter Property="Foreground" Value="{StaticResource PosTextPrimaryBrush}" />

        </Style>

        <Style x:Key="EditTabSaveButtonStyle" TargetType="Button" BasedOn="{StaticResource TabsSlideFooterButtonStyle}">

            <Setter Property="MinWidth" Value="0" />

            <Setter Property="MinHeight" Value="56" />

            <Setter Property="HorizontalAlignment" Value="Stretch" />

            <Setter Property="Background" Value="{StaticResource PosButtonPrimaryBrush}" />

            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="Foreground" Value="{StaticResource PosOnAccentForegroundBrush}" />

            <Setter Property="FontWeight" Value="SemiBold" />

        </Style>

        <Style x:Key="EditTabDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">

            <Setter Property="MinHeight" Value="44" />

            <Setter Property="HorizontalAlignment" Value="Stretch" />

            <Setter Property="Background" Value="Transparent" />

            <Setter Property="BorderBrush" Value="{StaticResource PosButtonDangerBrush}" />

            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="CornerRadius" Value="10" />

            <Setter Property="Foreground" Value="{StaticResource PosButtonDangerBrush}" />

            <Setter Property="FontSize" Value="14" />

            <Setter Property="FontWeight" Value="SemiBold" />

        </Style>

    </UserControl.Resources>

    <Grid Padding="12,10,12,20">

        <Grid.RowDefinitions>

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>

        <ScrollViewer

            Grid.Row="0"

            HorizontalScrollBarVisibility="Disabled"

            VerticalScrollBarVisibility="Auto">

            <StackPanel Spacing="12">

                <TextBlock

                    FontSize="22"

                    FontWeight="SemiBold"

                    Foreground="{StaticResource PosTextPrimaryBrush}"

                    Text="Edit tab" />

                <TextBlock

                    FontSize="12"

                    Foreground="{StaticResource PosBalanceNegativeBrush}"

                    Text="{Binding StatusMessage, Mode=OneWay}"

                    TextWrapping="WrapWholeWords"

                    Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, Mode=OneWay}" />

                <StackPanel Spacing="4">

                    <TextBlock

                        FontSize="11"

                        FontWeight="SemiBold"

                        Foreground="{StaticResource PosTextSecondaryBrush}"

                        Text="Tab name" />

                    <Button

                        Command="{Binding BeginNameEntryCommand}"

                        FontSize="15"

                        Style="{StaticResource EditTabTapFieldStyle}">

                        <TextBlock Text="{Binding NameEntrySummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />

                    </Button>

                </StackPanel>

                <StackPanel

                    Spacing="4"

                    Visibility="{Binding IsMemberTab, Converter={StaticResource BoolToVis}, Mode=OneWay}">

                    <TextBlock

                        FontSize="11"

                        FontWeight="SemiBold"

                        Foreground="{StaticResource PosTextSecondaryBrush}"

                        Text="Member link id" />

                    <Button

                        Command="{Binding BeginMemberIdEntryCommand}"

                        FontSize="14"

                        Style="{StaticResource EditTabTapFieldStyle}">

                        <TextBlock Text="{Binding MemberIdSummary, Mode=OneWay}" TextTrimming="CharacterEllipsis" />

                    </Button>

                </StackPanel>

                <StackPanel Spacing="4">

                    <TextBlock

                        FontSize="11"

                        FontWeight="SemiBold"

                        Foreground="{StaticResource PosTextSecondaryBrush}"

                        Text="Notes" />

                    <Button

                        MinHeight="56"

                        Command="{Binding BeginNotesEntryCommand}"

                        FontSize="14"

                        Style="{StaticResource EditTabTapFieldStyle}">

                        <TextBlock

                            MaxLines="4"

                            Text="{Binding NotesSummary, Mode=OneWay}"

                            TextTrimming="CharacterEllipsis"

                            TextWrapping="WrapWholeWords" />

                    </Button>

                </StackPanel>

                <Button

                    Command="{Binding DeleteTabCommand}"

                    Content="Delete tab"

                    Style="{StaticResource EditTabDeleteButtonStyle}"

                    Visibility="{Binding ShowDeleteTab, Converter={StaticResource BoolToVis}, Mode=OneWay}" />

            </StackPanel>

        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,12,0,0" ColumnSpacing="10">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*" />

                <ColumnDefinition Width="*" />

            </Grid.ColumnDefinitions>

            <Button

                Grid.Column="0"

                Command="{Binding CancelCommand}"

                Content="Cancel"

                Style="{StaticResource TabsSlideFooterButtonStyle}" />

            <Button

                Grid.Column="1"

                Command="{Binding SaveCommand}"

                Content="Save"

                Style="{StaticResource EditTabSaveButtonStyle}" />

        </Grid>

    </Grid>

</UserControl>

