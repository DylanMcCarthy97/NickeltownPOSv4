<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Views.Panels.BarModeHelpPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="{StaticResource PosTextPrimaryBrush}"
            Text="Bar mode help" />
        <ScrollViewer
            Grid.Row="1"
            Margin="0,10,0,0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <TextBlock
                FontSize="13"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="{Binding HelpText, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </ScrollViewer>
        <Button
            Grid.Row="2"
            MinHeight="44"
            Margin="0,10,0,0"
            HorizontalAlignment="Stretch"
            Command="{Binding CloseCommand}"
            Content="Close"
            Style="{StaticResource TabsPagerButtonStyle}" />
    </Grid>
</UserControl>
