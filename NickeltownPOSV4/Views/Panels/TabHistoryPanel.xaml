<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Views.Panels.TabHistoryPanel"
    x:Name="RootHist"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:NickeltownPOSV4.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:ArgbStringToBrushConverter x:Key="ArgbBrush" />
        <SolidColorBrush x:Key="MonthHeaderBgBrush" Color="#FF4682B4" />
        <SolidColorBrush x:Key="MonthHeaderFgBrush" Color="White" />
        <Style x:Key="HistoryChipStyle" TargetType="Button" BasedOn="{StaticResource TabsPagerButtonStyle}">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <Grid Padding="12,10,12,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Foreground="{StaticResource PosTextPrimaryBrush}"
            Text="{Binding Header, Mode=OneWay}"
            TextWrapping="WrapWholeWords" />

        <TextBlock
            Grid.Row="1"
            Margin="0,6,0,0"
            FontSize="12"
            FontWeight="SemiBold"
            Foreground="{StaticResource PosTextPrimaryBrush}"
            Text="{Binding RangeSummary, Mode=OneWay}"
            TextWrapping="WrapWholeWords" />

        <StackPanel Grid.Row="2" Margin="0,10,0,0" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button
                    Command="{Binding PresetAllTimeCommand}"
                    Content="All time"
                    Opacity="{Binding PresetAllOpacity, Mode=OneWay}"
                    Style="{StaticResource HistoryChipStyle}" />
                <Button
                    Command="{Binding PresetThisMonthCommand}"
                    Content="This month"
                    Opacity="{Binding PresetThisMonthOpacity, Mode=OneWay}"
                    Style="{StaticResource HistoryChipStyle}" />
                <Button
                    Command="{Binding PresetLastMonthCommand}"
                    Content="Last month"
                    Opacity="{Binding PresetLastMonthOpacity, Mode=OneWay}"
                    Style="{StaticResource HistoryChipStyle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button
                    Command="{Binding PresetLast90DaysCommand}"
                    Content="Last 90 days"
                    Opacity="{Binding PresetLast90Opacity, Mode=OneWay}"
                    Style="{StaticResource HistoryChipStyle}" />
                <Button
                    Command="{Binding PresetCustomCommand}"
                    Content="Custom..."
                    Opacity="{Binding PresetCustomOpacity, Mode=OneWay}"
                    Style="{StaticResource HistoryChipStyle}" />
            </StackPanel>
        </StackPanel>

        <StackPanel
            Grid.Row="3"
            Margin="0,10,0,0"
            Spacing="8"
            Visibility="{Binding IsCustomPreset, Converter={StaticResource BoolToVis}, Mode=OneWay}">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="Custom range (local dates)"
                TextWrapping="WrapWholeWords" />
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CalendarDatePicker
                    Grid.Column="0"
                    Header="From"
                    Date="{Binding CustomStart, Mode=TwoWay}" />
                <CalendarDatePicker
                    Grid.Column="1"
                    Header="Through"
                    Date="{Binding CustomEnd, Mode=TwoWay}" />
            </Grid>
            <Button
                HorizontalAlignment="Stretch"
                Command="{Binding ApplyCustomRangeCommand}"
                Content="Apply range"
                Style="{StaticResource TabsSlideFooterButtonStyle}" />
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,8,0,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="{Binding Status, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
            <Button
                Grid.Column="1"
                MinHeight="36"
                Padding="10,4"
                Command="{Binding SelectAllCommand}"
                Content="All"
                FontSize="12"
                Style="{StaticResource TabsPagerButtonDenseStyle}" />
            <Button
                Grid.Column="2"
                MinHeight="36"
                Padding="10,4"
                Command="{Binding SelectNoneCommand}"
                Content="None"
                FontSize="12"
                Style="{StaticResource TabsPagerButtonDenseStyle}" />
        </Grid>

        <ScrollViewer
            Grid.Row="5"
            Margin="0,0,0,8"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding MonthGroups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TabHistoryMonthGroupViewModel">
                        <StackPanel Margin="0,0,0,12" Spacing="4">
                            <Border
                                Padding="8,6"
                                Background="{StaticResource MonthHeaderBgBrush}"
                                CornerRadius="6">
                                <CheckBox
                                    Content="{x:Bind MonthLabel}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource MonthHeaderFgBrush}"
                                    IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                            </Border>
                            <ItemsControl ItemsSource="{x:Bind Entries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TabHistoryEntryItemViewModel">
                                        <Border
                                            Margin="0,2,0,2"
                                            Padding="4,2,4,6"
                                            BorderBrush="{StaticResource PosBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}">
                                                <StackPanel Spacing="4">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="132" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource PosTextPrimaryBrush}"
                                                            Text="{x:Bind WhenDisplay}"
                                                            TextWrapping="NoWrap" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            FontSize="12"
                                                            Foreground="{x:Bind TypeColorArgb, Converter={StaticResource ArgbBrush}}"
                                                            Text="{x:Bind EntryType}"
                                                            TextWrapping="NoWrap" />
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            FontSize="12"
                                                            Foreground="{StaticResource PosTextSecondaryBrush}"
                                                            Text="{x:Bind PaymentMethod}"
                                                            TextWrapping="NoWrap" />
                                                        <TextBlock
                                                            Grid.Column="3"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource PosTextPrimaryBrush}"
                                                            Text="{x:Bind AmountDisplay}"
                                                            TextWrapping="NoWrap" />
                                                        <TextBlock
                                                            Grid.Column="4"
                                                            FontSize="12"
                                                            Foreground="{StaticResource PosTextSecondaryBrush}"
                                                            Text="{x:Bind Bartender}"
                                                            TextWrapping="NoWrap" />
                                                    </Grid>
                                                    <TextBlock
                                                        FontSize="12"
                                                        Foreground="{StaticResource PosTextPrimaryBrush}"
                                                        Text="{x:Bind Details}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </CheckBox>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="6" Margin="0,8,0,0" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                Command="{Binding ExportPdfCommand}"
                Content="Export selected to PDF"
                FontSize="15"
                Style="{StaticResource TabsSlideFooterButtonStyle}" />
            <Button
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Command="{Binding CloseCommand, Mode=OneWay}"
                Content="Close"
                Style="{StaticResource TabsSlideFooterButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>
