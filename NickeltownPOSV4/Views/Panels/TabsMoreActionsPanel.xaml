<?xml version="1.0" encoding="utf-8"?>

<UserControl

    x:Class="NickeltownPOSV4.Views.Panels.TabsMoreActionsPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:conv="using:NickeltownPOSV4.Converters"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

    </UserControl.Resources>

    <Grid Padding="14,12">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <TextBlock

            Grid.Row="0"

            FontSize="22"

            FontWeight="SemiBold"

            Foreground="{StaticResource PosTextPrimaryBrush}"

            Text="More actions" />



        <TextBlock

            Grid.Row="1"

            Margin="0,6,0,0"

            FontSize="12"

            Foreground="{StaticResource PosTextSecondaryBrush}"

            Text="Guest closeout, undo, and workspace tools"

            TextWrapping="WrapWholeWords" />



        <Button

            Grid.Row="2"

            MinHeight="48"

            Margin="0,14,0,0"

            HorizontalAlignment="Stretch"

            Command="{Binding OpenGuestCloseoutCommand}"

            Content="Guest closeout"

            FontSize="15"

            FontWeight="SemiBold"

            Style="{StaticResource TabsPagerButtonStyle}" />



        <Button

            Grid.Row="3"

            MinHeight="48"

            Margin="0,8,0,0"

            HorizontalAlignment="Stretch"

            Command="{Binding UndoLastCommand}"

            Content="Undo last"

            FontSize="15"

            FontWeight="SemiBold"

            Style="{StaticResource TabsPagerButtonStyle}"

            ToolTipService.ToolTip="{Binding UndoToolTip, Mode=OneWay}" />



        <Button

            Grid.Row="4"

            MinHeight="48"

            Margin="0,8,0,0"

            HorizontalAlignment="Stretch"

            Command="{Binding InfoCommand}"

            Content="Tabs board help"

            FontSize="15"

            FontWeight="SemiBold"

            Style="{StaticResource TabsPagerButtonStyle}" />



        <Button

            Grid.Row="5"

            MinHeight="48"

            Margin="0,8,0,0"

            HorizontalAlignment="Stretch"

            Command="{Binding SettingsCommand}"

            Content="Store settings"

            FontSize="15"

            FontWeight="SemiBold"

            Style="{StaticResource TabsHeaderActionButtonStyle}" />



        <Button

            Grid.Row="6"

            MinHeight="48"

            Margin="0,8,0,0"

            HorizontalAlignment="Stretch"

            Command="{Binding OpenStockManagementCommand}"

            Content="Stock management"

            FontSize="15"

            FontWeight="SemiBold"

            Style="{StaticResource TabsPagerButtonStyle}"

            Visibility="{Binding ShowStockManagementEntry, Converter={StaticResource BoolToVis}, Mode=OneWay}" />



        <Button

            Grid.Row="7"

            MinHeight="48"

            Margin="0,12,0,0"

            HorizontalAlignment="Stretch"

            Command="{Binding CloseSlidePanelCommand}"

            Content="Close"

            FontSize="15"

            FontWeight="SemiBold"

            Style="{StaticResource TabsHeaderActionButtonStyle}" />

    </Grid>

</UserControl>

