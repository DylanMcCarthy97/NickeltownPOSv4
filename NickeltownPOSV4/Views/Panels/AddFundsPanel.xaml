<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Views.Panels.AddFundsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <SolidColorBrush x:Key="FundsTileIdleBrush" Color="#FFF8FBFF" />
        <SolidColorBrush x:Key="FundsTileBorderBrush" Color="#FFD3E0F8" />
        <!-- Light chip behind Square mark so the PNG reads on the same light tile as other types -->
        <SolidColorBrush x:Key="FundsSquareTileBgBrush" Color="#FFE8EDF5" />

        <Style x:Key="FundsGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style x:Key="FundsFooterCancelStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="FundsFooterApplyStyle" TargetType="Button" BasedOn="{StaticResource TabsPagerButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Background" Value="{StaticResource PosAccentBrush}" />
            <Setter Property="BorderBrush" Value="#FF1E4FD6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PosCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="12,10,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="0,0,0,6"
                Padding="10,8"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="ADD FUNDS" />
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="{Binding TargetTabTitle, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="{Binding CurrentBalanceText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="1"
                Margin="0,0,0,6"
                Padding="10,8"
                Background="#FFE8F8EE"
                BorderBrush="#FF9AD9B0"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding HasSuccessBanner, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#FF166534"
                    Text="{Binding SuccessBanner, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </Border>

            <TextBlock
                Grid.Row="2"
                Margin="0,0,0,6"
                FontSize="11"
                Foreground="{StaticResource PosBalanceNegativeBrush}"
                Text="{Binding StatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords"
                Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, Mode=OneWay}" />

            <Border
                Grid.Row="3"
                Margin="0,0,0,6"
                Padding="10,8"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Amount" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="AmountInput"
                            Grid.Column="0"
                            Style="{StaticResource PosTouchFieldTextBoxStyle}"
                            Text="{Binding AmountDisplay, Mode=OneWay}" />
                        <Button
                            Grid.Column="1"
                            MinWidth="118"
                            MinHeight="46"
                            VerticalAlignment="Stretch"
                            Command="{Binding BeginAmountEntryCommand}"
                            Content="Enter amount"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Style="{StaticResource TabsHeaderActionButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border
                Grid.Row="4"
                Margin="0,0,0,6"
                Padding="10,8"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="Note" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="NotesInput"
                            Grid.Column="0"
                            MinHeight="44"
                            MaxHeight="56"
                            Padding="10,8"
                            FontSize="13"
                            Style="{StaticResource PosTouchFieldTextBoxStyle}"
                            PlaceholderText="Optional"
                            Text="{Binding Notes, Mode=OneWay}"
                            TextWrapping="Wrap" />
                        <Button
                            Grid.Column="1"
                            MinWidth="118"
                            MinHeight="46"
                            VerticalAlignment="Stretch"
                            Command="{Binding BeginNotesEntryCommand}"
                            Content="Type note"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Style="{StaticResource TabsHeaderActionButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock
                Grid.Row="5"
                Margin="0,0,0,4"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="Transaction type" />

            <GridView
                Grid.Row="6"
                HorizontalAlignment="Stretch"
                IsEnabled="{Binding CanEditFields, Mode=OneWay}"
                IsItemClickEnabled="False"
                ItemContainerStyle="{StaticResource FundsGridViewItemStyle}"
                ItemsSource="{Binding Types, Mode=OneWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollMode="Disabled"
                SelectedItem="{Binding SelectedTile, Mode=TwoWay}"
                SelectionMode="Single">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid
                            HorizontalAlignment="Stretch"
                            ItemHeight="84"
                            ItemWidth="188"
                            MaximumRowsOrColumns="2"
                            Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            Margin="2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <Border
                                Height="76"
                                Padding="8,6"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{Binding TileBackgroundBrush, Mode=OneWay}"
                                BorderBrush="{Binding TileBorderBrush, Mode=OneWay}"
                                BorderThickness="{Binding TileBorderThickness, Mode=OneWay}"
                                CornerRadius="10">
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="22"
                                        Text="{Binding Emoji, Mode=OneWay}"
                                        TextAlignment="Center"
                                        Visibility="{Binding IsSquareBrand, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, Mode=OneWay}" />
                                    <Border
                                        Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Padding="4"
                                        Background="{StaticResource FundsSquareTileBgBrush}"
                                        CornerRadius="8"
                                        Visibility="{Binding IsSquareBrand, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                                        <Image
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            MaxWidth="28"
                                            MaxHeight="28"
                                            Stretch="Uniform"
                                            Source="ms-appx:///Assets/SquareCardLogo.png" />
                                    </Border>
                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource PosTextPrimaryBrush}"
                                            Text="{Binding DisplayName, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                        <TextBlock
                                            FontSize="9"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource PosTextSecondaryBrush}"
                                            Text="SQUARE"
                                            Visibility="{Binding IsSquareBrand, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <TextBlock
                                Margin="0,4,6,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="{StaticResource PosAccentBrush}"
                                IsHitTestVisible="False"
                                Text="✓"
                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Border
                Grid.Row="7"
                Margin="0,6,0,0"
                Padding="8,6"
                Background="#FFF5F9FF"
                BorderBrush="#FFCBDCF8"
                BorderThickness="1"
                CornerRadius="8">
                <TextBlock
                    FontSize="11"
                    Foreground="{StaticResource PosTextPrimaryBrush}"
                    Text="{Binding FooterHint, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </Border>
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="10,8,10,10"
            Background="{StaticResource PosSurfaceBrush}"
            BorderBrush="{StaticResource PosBorderBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Command="{Binding CancelCommand, Mode=OneWay}"
                Content="Cancel"
                FontSize="14"
                FontWeight="SemiBold"
                Style="{StaticResource FundsFooterCancelStyle}" />

            <Button
                Grid.Column="1"
                Command="{Binding ApplyCommand, Mode=OneWay}"
                Content="Add Funds"
                FontWeight="SemiBold"
                Style="{StaticResource FundsFooterApplyStyle}" />
        </Grid>

        <Grid
            Grid.RowSpan="2"
            Background="#CC0F172A"
            Canvas.ZIndex="60"
            Visibility="{Binding ShowSendingSquareOverlay, Converter={StaticResource BoolToVis}, Mode=OneWay}">
            <Border
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource PosSurfaceBrush}"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel MinWidth="320" Spacing="12">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosTextPrimaryBrush}"
                        Text="Processing card payment…" />
                    <TextBlock
                        FontSize="14"
                        Foreground="{StaticResource PosTextSecondaryBrush}"
                        Text="{Binding SquareWaitingMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <Button
                        HorizontalAlignment="Center"
                        MinWidth="200"
                        Command="{Binding CancelSquarePaymentCommand, Mode=OneWay}"
                        Content="Cancel payment"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Style="{StaticResource TabsHeaderActionButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
