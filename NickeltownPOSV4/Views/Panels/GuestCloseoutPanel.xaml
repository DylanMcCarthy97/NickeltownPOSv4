<?xml version="1.0" encoding="utf-8"?>

<UserControl

    x:Class="NickeltownPOSV4.Views.Panels.GuestCloseoutPanel"

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:conv="using:NickeltownPOSV4.Converters"

    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

    mc:Ignorable="d">

    <UserControl.Resources>

        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="GuestCloseoutBulkButtonStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">

            <Setter Property="MinWidth" Value="0" />

            <Setter Property="MinHeight" Value="46" />

            <Setter Property="Padding" Value="10,10" />

            <Setter Property="HorizontalAlignment" Value="Stretch" />

            <Setter Property="HorizontalContentAlignment" Value="Center" />

            <Setter Property="FontSize" Value="13" />

            <Setter Property="FontWeight" Value="SemiBold" />

        </Style>

        <Style x:Key="GuestCloseoutRowActionStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">

            <Setter Property="MinWidth" Value="0" />

            <Setter Property="MinHeight" Value="42" />

            <Setter Property="Padding" Value="10,8" />

            <Setter Property="FontSize" Value="12" />

            <Setter Property="FontWeight" Value="SemiBold" />

        </Style>

        <Style x:Key="GuestCloseoutPayButtonStyle" TargetType="Button" BasedOn="{StaticResource GuestCloseoutRowActionStyle}">

            <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />

        </Style>

        <Style x:Key="GuestCloseoutRowSelectStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
        </Style>

        <Style x:Key="GuestCloseoutFooterButtonStyle" TargetType="Button" BasedOn="{StaticResource TabsHeaderActionButtonStyle}">

            <Setter Property="MinWidth" Value="0" />

            <Setter Property="MinHeight" Value="48" />

            <Setter Property="Padding" Value="12,10" />

            <Setter Property="HorizontalAlignment" Value="Stretch" />

            <Setter Property="HorizontalContentAlignment" Value="Center" />

            <Setter Property="FontSize" Value="14" />

            <Setter Property="FontWeight" Value="SemiBold" />

        </Style>

    </UserControl.Resources>



    <Grid Padding="14,12,14,16">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="*" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <TextBlock

            FontSize="20"

            FontWeight="SemiBold"

            Foreground="{StaticResource PosTextPrimaryBrush}"

            Text="Guest closeout" />

        <TextBlock

            Grid.Row="1"

            Margin="0,6,0,0"

            FontSize="12"

            Foreground="{StaticResource PosTextSecondaryBrush}"

            LineHeight="16"

            Text="Tap a guest name to select for Drinks. Use Pay to settle, then close or archive when clear."

            TextWrapping="WrapWholeWords" />

        <TextBlock

            Grid.Row="2"

            Margin="0,6,0,0"

            FontSize="12"

            Foreground="{StaticResource PosBalanceNegativeBrush}"

            Text="{Binding StatusMessage, Mode=OneWay}"

            TextWrapping="WrapWholeWords"

            Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, Mode=OneWay}" />



        <ListView

            Grid.Row="3"

            Margin="0,10,0,0"

            HorizontalAlignment="Stretch"

            IsItemClickEnabled="False"

            ItemsSource="{Binding Lines, Mode=OneWay}"

            SelectionMode="None"

            VerticalAlignment="Stretch">

            <ListView.ItemContainerStyle>

                <Style TargetType="ListViewItem">

                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />

                    <Setter Property="Padding" Value="0" />

                    <Setter Property="MinHeight" Value="0" />

                </Style>

            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>

                <DataTemplate>

                    <Border

                        Margin="0,0,0,8"

                        Padding="10,8"

                        Background="{StaticResource PosSurfaceAltBrush}"

                        BorderBrush="{StaticResource PosBorderBrush}"

                        BorderThickness="1"

                        CornerRadius="10">

                        <Grid ColumnSpacing="8">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="Auto" />

                                <ColumnDefinition Width="*" />

                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <CheckBox

                                Grid.Column="0"

                                VerticalAlignment="Top"

                                Margin="0,2,0,0"

                                IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                            <Button

                                Grid.Column="1"

                                MinHeight="0"

                                Padding="0"

                                HorizontalAlignment="Stretch"

                                HorizontalContentAlignment="Stretch"

                                Background="Transparent"

                                BorderThickness="0"

                                Command="{Binding SelectOnBoardCommand}"

                                Style="{StaticResource GuestCloseoutRowSelectStyle}">

                                <StackPanel Spacing="3">

                                    <TextBlock

                                        FontSize="15"

                                        FontWeight="SemiBold"

                                        Foreground="{StaticResource PosTextPrimaryBrush}"

                                        Text="{Binding DisplayName, Mode=OneWay}"

                                        TextTrimming="CharacterEllipsis" />

                                    <TextBlock

                                        FontSize="13"

                                        FontWeight="SemiBold"

                                        Foreground="{StaticResource PosTextPrimaryBrush}"

                                        Text="{Binding BalanceText, Mode=OneWay}" />

                                    <TextBlock

                                        MaxLines="2"

                                        FontSize="11"

                                        Foreground="{StaticResource PosTextSecondaryBrush}"

                                        LineHeight="14"

                                        Text="{Binding ActivityLine, Mode=OneWay}"

                                        TextWrapping="WrapWholeWords" />

                                </StackPanel>

                            </Button>

                            <StackPanel

                                Grid.Column="2"

                                Width="76"

                                Spacing="6"

                                VerticalAlignment="Center">

                                <Button

                                    Command="{Binding OpenDrinksCommand}"

                                    Content="Drinks"

                                    Style="{StaticResource GuestCloseoutRowActionStyle}" />

                                <Button

                                    Command="{Binding RecordPaymentCommand}"

                                    Content="Pay"

                                    Style="{StaticResource GuestCloseoutPayButtonStyle}"

                                    ToolTipService.ToolTip="Record cash or settle credit" />

                            </StackPanel>

                        </Grid>

                    </Border>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>



        <Border

            Grid.Row="4"

            Margin="0,12,0,0"

            Padding="0,12,0,0"

            BorderBrush="{StaticResource PosBorderBrush}"

            BorderThickness="0,1,0,0">

            <StackPanel Spacing="10">

                <Grid ColumnSpacing="8">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>

                    <Button

                        Grid.Column="0"

                        Command="{Binding SelectAllCommand}"

                        Content="Select all"

                        Style="{StaticResource GuestCloseoutFooterButtonStyle}" />

                    <Button

                        Grid.Column="1"

                        Command="{Binding SelectNoneCommand}"

                        Content="Select none"

                        Style="{StaticResource GuestCloseoutFooterButtonStyle}" />

                </Grid>

                <Grid ColumnSpacing="8">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>

                    <Button

                        Grid.Column="0"

                        Command="{Binding CloseSelectedCommand}"

                        Content="Close selected"

                        Style="{StaticResource GuestCloseoutBulkButtonStyle}"

                        ToolTipService.ToolTip="End of night — close selected $0 guests" />

                    <Button

                        Grid.Column="1"

                        Command="{Binding CloseZeroCommand}"

                        Content="Close all $0"

                        Style="{StaticResource GuestCloseoutBulkButtonStyle}" />

                </Grid>

                <Grid ColumnSpacing="8" Visibility="{Binding CanAdminArchive, Converter={StaticResource BoolToVis}, Mode=OneWay}">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>

                    <Button

                        Grid.Column="0"

                        Command="{Binding ArchiveSelectedCommand}"

                        Content="Archive selected"

                        Style="{StaticResource GuestCloseoutBulkButtonStyle}" />

                    <Button

                        Grid.Column="1"

                        Command="{Binding ArchiveAllCommand}"

                        Content="Archive all"

                        Style="{StaticResource GuestCloseoutBulkButtonStyle}" />

                </Grid>

                <Grid ColumnSpacing="10">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>

                    <Button

                        Grid.Column="0"

                        Command="{Binding CloseCommand}"

                        Content="Close panel"

                        Style="{StaticResource GuestCloseoutFooterButtonStyle}" />

                    <Button

                        Grid.Column="1"

                        Command="{Binding RefreshCommand}"

                        Content="Refresh"

                        Style="{StaticResource GuestCloseoutFooterButtonStyle}" />

                </Grid>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>

