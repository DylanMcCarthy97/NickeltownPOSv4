<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Views.Panels.AddDrinksPanel"
    x:Name="RootGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NickeltownPOSV4.Controls"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:panels="using:NickeltownPOSV4.Views.Panels"
    xmlns:vm="using:NickeltownPOSV4.ViewModels"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolNegateConverter x:Key="BoolNeg" />
        <conv:BoolToBrushConverter x:Key="BoolToAccentBorder" />
        <conv:BoolToThicknessConverter x:Key="InCartOutlineThickness" SelectedThickness="2" UnselectedThickness="1" />
        <conv:AddDrinksChipBackgroundConverter x:Key="ChipBg" />
        <conv:AddDrinksChipForegroundConverter x:Key="ChipFg" />

        <!-- Product tile (standard catalog card). Vertical layout: top pad / image / name / price / stock. -->
        <DataTemplate x:Key="AddDrinksProductTileTemplate" x:DataType="vm:DrinkCardItem">
            <Grid Width="210" Height="222" Margin="3,3" Opacity="{x:Bind CardOpacity}">
                <Border
                    Background="{StaticResource PosInCartHighlightBrush}"
                    CornerRadius="12"
                    Opacity="0.55"
                    Visibility="{x:Bind IsInCart, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                <Border
                    Background="{StaticResource PosSurfaceBrush}"
                    BorderBrush="{x:Bind IsInCart, Mode=OneWay, Converter={StaticResource BoolToAccentBorder}}"
                    BorderThickness="{x:Bind IsInCart, Mode=OneWay, Converter={StaticResource InCartOutlineThickness}}"
                    CornerRadius="12">
                    <Grid>
                        <!-- Main clickable surface fills the entire card. -->
                        <Button
                            Padding="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding DataContext.AddDrinkCommand, ElementName=RootGrid}"
                            CommandParameter="{Binding}"
                            IsEnabled="{x:Bind CanAddFromCatalog}"
                            Style="{StaticResource CatalogProductButtonStyle}"
                            UseSystemFocusVisuals="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="104" />
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="50" />
                                    <RowDefinition Height="10" />
                                </Grid.RowDefinitions>

                                <!-- Image area (~96x96 inside a 104px row). -->
                                <Border
                                    Grid.Row="1"
                                    Width="96"
                                    Height="96"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource PosProductThumbFillBrush}"
                                    BorderBrush="{StaticResource PosProductThumbBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                    <controls:CatalogProductImage
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ImagePath="{x:Bind ImagePath, Mode=OneWay}" />
                                </Border>

                                <!-- Product name (2 lines max, centered). -->
                                <TextBlock
                                    Grid.Row="2"
                                    Margin="8,0"
                                    VerticalAlignment="Top"
                                    MaxLines="2"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                    LineHeight="18"
                                    Text="{x:Bind Name, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="WrapWholeWords" />

                                <!-- Bottom info: price centered, stock label centered below. Hidden when out of stock. -->
                                <StackPanel
                                    Grid.Row="4"
                                    Margin="10,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="2"
                                    Visibility="{x:Bind ShowOutOfStockOverlay, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">

                                    <!-- Standard price (when no special pricing). -->
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource PosTextPrimaryBrush}"
                                        Text="{x:Bind PriceText, Mode=OneWay}"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        Visibility="{x:Bind ShowSpecialPricing, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

                                    <!-- Special pricing: red special price with strikethrough regular next to it. -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        Visibility="{x:Bind ShowSpecialPricing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource PosSpecialPriceBrush}"
                                            Text="{x:Bind SpecialPriceText, Mode=OneWay}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{StaticResource PosTextSecondaryBrush}"
                                            Text="{x:Bind RegularPriceText, Mode=OneWay}"
                                            TextDecorations="Strikethrough" />
                                    </StackPanel>

                                    <!-- Stock label (centered below price). -->
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{StaticResource PosTextSecondaryBrush}"
                                        Text="{x:Bind CleanStockLabel, Mode=OneWay}"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        Visibility="{x:Bind ShowCleanStockLabel, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Top-right: favourite heart toggle (always present). -->
                        <Button
                            Width="48"
                            Height="48"
                            Margin="0,4,4,0"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=RootGrid}"
                            CommandParameter="{Binding}"
                            CornerRadius="24"
                            UseSystemFocusVisuals="False">
                            <Grid>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="28"
                                    Foreground="#E63946"
                                    Text="&#x2665;"
                                    Visibility="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="28"
                                    Foreground="#9CA3AF"
                                    Text="&#x2661;"
                                    Visibility="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                            </Grid>
                        </Button>

                        <!-- Top-left: added-to-cart badge ("✓ Added" / "×N"). -->
                        <Border
                            Margin="4,4,0,0"
                            Padding="8,3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{StaticResource PosCartQtyBadgeBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind ShowCartQtyBadge, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{x:Bind CartQtyBadgeText, Mode=OneWay}" />
                        </Border>

                        <!-- Bottom-center: compact out-of-stock pill (replaces price/stock row when out of stock). -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="8,3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Background="#FEE2E2"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{x:Bind ShowOutOfStockOverlay, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock
                                FontSize="10.5"
                                FontWeight="SemiBold"
                                Foreground="#B91C1C"
                                Text="&#x274C; Out of stock" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Shot + Mixer tile: same look as product cards; ShotMixerCommand handles the different flow. -->
        <DataTemplate x:Key="AddDrinksShotMixerTileTemplate" x:DataType="vm:ShotMixerCatalogTile">
            <Grid Width="210" Height="222" Margin="3,3">
                <Border
                    Background="{StaticResource PosSurfaceBrush}"
                    BorderBrush="{StaticResource PosPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Button
                        Padding="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding DataContext.ShotMixerCommand, ElementName=RootGrid}"
                        CornerRadius="12"
                        Style="{StaticResource CatalogProductButtonStyle}"
                        UseSystemFocusVisuals="False">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="10" />
                                <RowDefinition Height="104" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="50" />
                                <RowDefinition Height="10" />
                            </Grid.RowDefinitions>

                            <Border
                                Grid.Row="1"
                                Width="96"
                                Height="96"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{StaticResource PosProductThumbFillBrush}"
                                BorderBrush="{StaticResource PosProductThumbBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Viewbox
                                    Margin="4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Stretch="Uniform"
                                    StretchDirection="DownOnly">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe UI Emoji"
                                            FontSize="40"
                                            Text="&#x1F943;" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="28"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource PosTextSecondaryBrush}"
                                            Text="+" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe UI Emoji"
                                            FontSize="40"
                                            Text="&#x1F964;" />
                                    </StackPanel>
                                </Viewbox>
                            </Border>

                            <TextBlock
                                Grid.Row="2"
                                Margin="8,0"
                                VerticalAlignment="Top"
                                MaxLines="2"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                LineHeight="18"
                                Text="{x:Bind Name, Mode=OneWay}"
                                TextAlignment="Center"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="WrapWholeWords" />

                            <StackPanel
                                Grid.Row="4"
                                Margin="10,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="2">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                    Text="{x:Bind PriceText, Mode=OneWay}"
                                    TextAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{x:Bind ShowSpecialPricing, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="6"
                                    Visibility="{x:Bind ShowSpecialPricing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource PosSpecialPriceBrush}"
                                        Text="{x:Bind SpecialPriceText, Mode=OneWay}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="{StaticResource PosTextSecondaryBrush}"
                                        Text="{x:Bind RegularPriceText, Mode=OneWay}"
                                        TextDecorations="Strikethrough" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Button>
                </Border>
            </Grid>
        </DataTemplate>

        <panels:AddDrinksCatalogTileTemplateSelector
            x:Key="AddDrinksCatalogTileSelector"
            ProductTemplate="{StaticResource AddDrinksProductTileTemplate}"
            ShotMixerTemplate="{StaticResource AddDrinksShotMixerTileTemplate}" />
    </UserControl.Resources>

    <Grid
        x:Name="AddDrinksLayoutRoot"
        Background="{StaticResource PosPanelCanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox
            x:Name="ScanSkuTextBox"
            Width="1"
            Height="1"
            MinWidth="1"
            MinHeight="1"
            Margin="-10000,0,0,0"
            Opacity="0"
            IsTabStop="True"
            KeyDown="ScanSkuTextBox_KeyDown"
            Loaded="ScanSkuTextBox_Loaded"
            Text="{Binding PendingScanCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Row 0: Header (dark Nickeltown POS bar, matches Tabs) -->
        <Border
            Grid.Row="0"
            Padding="14,10,14,10"
            Background="{StaticResource PosHeaderBackgroundBrush}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button
                        MinWidth="88"
                        MinHeight="44"
                        Command="{Binding CancelCommand, Mode=OneWay}"
                        Content="Back"
                        FontSize="12.5"
                        FontWeight="SemiBold"
                        Style="{StaticResource TabsHeaderActionButtonStyle}"
                        UseSystemFocusVisuals="False" />
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="{StaticResource PosOnDarkForegroundBrush}"
                            Text="Add Drinks" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource PosOnDarkSecondaryForegroundBrush}"
                            Text="{Binding WorkspaceSubtitle, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosOnDarkForegroundBrush}"
                        MaxLines="1"
                        Text="{Binding WorkspaceTabDisplayName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{Binding IsProjectedBalanceNegative, Converter={StaticResource BoolToAccentBorder}, Mode=OneWay}"
                        Text="{Binding WorkspaceBalanceDisplay, Mode=OneWay}" />
                </StackPanel>

                <Border
                    Grid.Column="2"
                    Padding="12,8"
                    VerticalAlignment="Center"
                    Background="{StaticResource PosAccentMutedBrush}"
                    BorderBrush="{StaticResource PosButtonPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource PosOnDarkForegroundBrush}"
                        Text="{Binding HeaderCartChipSummary, Mode=OneWay}"
                        TextAlignment="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Row 1: Status -->
        <TextBlock
            Grid.Row="1"
            Margin="14,6,14,4"
            FontSize="11"
            Foreground="{StaticResource PosBalanceNegativeBrush}"
            MaxLines="2"
            Text="{Binding StatusMessage, Mode=OneWay}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="WrapWholeWords"
            Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}, Mode=OneWay}" />

        <!-- Row 2: Catalog | Cart (62% / 38%) -->
        <Grid
            Grid.Row="2"
            Margin="12,4,12,8"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="31*" />
                <ColumnDefinition Width="19*" MinWidth="288" MaxWidth="360" />
            </Grid.ColumnDefinitions>

            <!-- Left: product board -->
            <Border
                Grid.Column="0"
                Padding="12,10,12,8"
                Background="{StaticResource PosPanelMutedSurfaceBrush}"
                BorderBrush="{StaticResource PosPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="120" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Products header: title + Showing/Clear-filter row + full-width category tile strip. -->
                    <StackPanel Grid.Row="0" Spacing="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                Text="Products" />

                            <TextBlock
                                Grid.Column="1"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                Text="{Binding CurrentFilterSummary, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />

                            <Button
                                Grid.Column="2"
                                MinHeight="30"
                                Padding="10,4"
                                VerticalAlignment="Center"
                                Command="{Binding SelectCategoryCommand, Mode=OneWay}"
                                CommandParameter="All"
                                CornerRadius="8"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Style="{StaticResource CartGhostButtonStyle}"
                                UseSystemFocusVisuals="False"
                                Visibility="{Binding HasActiveCategoryFilter, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock FontSize="11" Text="&#x2715;" />
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="Clear filter" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <ItemsControl
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding CategoryChips, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:UniformRowPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryChipItem">
                                    <Button
                                        Background="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource ChipBg}}"
                                        BorderBrush="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToAccentBorder}}"
                                        BorderThickness="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource InCartOutlineThickness}}"
                                        Command="{Binding DataContext.SelectCategoryCommand, ElementName=RootGrid}"
                                        CommandParameter="{x:Bind Label}"
                                        Foreground="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource ChipFg}}"
                                        Style="{StaticResource AddDrinksCategoryChipButtonStyle}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontFamily="Segoe UI Emoji"
                                                FontSize="22"
                                                Text="{x:Bind Glyph}"
                                                TextAlignment="Center" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                MaxLines="1"
                                                Text="{x:Bind DisplayLabel}"
                                                TextAlignment="Center"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Product grid fills remaining height; Viewbox scales down on 1024x768. -->
                    <Grid Grid.Row="1" VerticalAlignment="Stretch">
                        <Viewbox
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Stretch="Uniform"
                            StretchDirection="DownOnly">
                            <Grid Width="648" Height="456">
                                <ItemsControl
                                    ItemTemplateSelector="{StaticResource AddDrinksCatalogTileSelector}"
                                    ItemsSource="{Binding CatalogPageItems, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid
                                                ItemHeight="228"
                                                ItemWidth="216"
                                                MaximumRowsOrColumns="3"
                                                Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Grid>
                        </Viewbox>

                        <!-- Empty catalog -->
                        <StackPanel
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{Binding IsCatalogEmpty, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                            <FontIcon
                                HorizontalAlignment="Center"
                                FontSize="28"
                                Foreground="#A8B4C8"
                                Glyph="&#xE7BF;" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="13"
                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                Text="{Binding CatalogEmptyMessage, Mode=OneWay}"
                                TextAlignment="Center"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Grid>

                    <controls:CatalogPagePager
                        Grid.Row="2"
                        Margin="0,4,0,0"
                        IsNextEnabled="{Binding CanCatalogNext, Mode=OneWay}"
                        IsPreviousEnabled="{Binding CanCatalogPrev, Mode=OneWay}"
                        NextCommand="{Binding CatalogNextCommand, Mode=OneWay}"
                        PageLabel="{Binding CatalogPageLabel, Mode=OneWay}"
                        PreviousCommand="{Binding CatalogPrevCommand, Mode=OneWay}"
                        ShowPager="{Binding ShowCatalogPagination, Mode=OneWay}" />
                </Grid>
            </Border>

            <!-- Right: order cart -->
            <Border
                Grid.Column="1"
                Padding="14,12,14,14"
                Background="{StaticResource PosPanelMutedSurfaceBrush}"
                BorderBrush="{StaticResource PosPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="80" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                Text="Order" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{StaticResource PosTextSecondaryBrush}"
                                Text="{Binding CartLineCountSummary, Mode=OneWay}" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            Command="{Binding ClearCartCommand, Mode=OneWay}"
                            Content="Clear"
                            Style="{StaticResource CartGhostButtonStyle}"
                            UseSystemFocusVisuals="False" />
                    </Grid>

                    <Border
                        Grid.Row="1"
                        Background="{StaticResource PosSurfaceBrush}"
                        BorderBrush="{StaticResource PosPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <ScrollViewer
                                Padding="8"
                                VerticalScrollBarVisibility="Auto"
                                Visibility="{Binding IsCartEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=Invert, Mode=OneWay}">
                                <ItemsControl ItemsSource="{Binding SelectedRows, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SelectedDrinkRow">
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="10,10"
                                                Background="{StaticResource PosCartLineFillBrush}"
                                                BorderBrush="{StaticResource PosPanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                                <Grid RowSpacing="8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock
                                                            FontSize="14"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource PosTextPrimaryBrush}"
                                                            MaxLines="2"
                                                            Text="{x:Bind DrinkName, Mode=OneWay}"
                                                            TextWrapping="WrapWholeWords" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            MinWidth="64"
                                                            FontSize="15"
                                                            FontWeight="Bold"
                                                            Foreground="{StaticResource PosTextPrimaryBrush}"
                                                            Text="{x:Bind LineTotalText, Mode=OneWay}"
                                                            TextAlignment="Right" />
                                                    </Grid>
                                                    <TextBlock
                                                        Grid.Row="1"
                                                        FontSize="12"
                                                        Foreground="{StaticResource PosTextSecondaryBrush}"
                                                        Text="{x:Bind UnitPriceQtyLine, Mode=OneWay}" />
                                                    <Grid Grid.Row="2" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button
                                                            Command="{Binding DataContext.DecrementLineCommand, ElementName=RootGrid}"
                                                            CommandParameter="{Binding}"
                                                            Content="&#x2212;"
                                                            Style="{StaticResource CartQtyPadButtonStyle}" />
                                                        <Border
                                                            Grid.Column="1"
                                                            MinWidth="48"
                                                            MinHeight="44"
                                                            Padding="8,0"
                                                            Background="#F0F2F6"
                                                            BorderBrush="#CCD6E4"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                            <TextBlock
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="15"
                                                                FontWeight="SemiBold"
                                                                Text="{x:Bind QtyDisplay, Mode=OneWay}" />
                                                        </Border>
                                                        <Button
                                                            Grid.Column="2"
                                                            Command="{Binding DataContext.IncrementLineCommand, ElementName=RootGrid}"
                                                            CommandParameter="{Binding}"
                                                            Content="+"
                                                            Style="{StaticResource CartQtyPadButtonStyle}" />
                                                        <Button
                                                            Grid.Column="3"
                                                            HorizontalAlignment="Right"
                                                            Command="{Binding DataContext.RemoveLineCommand, ElementName=RootGrid}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource CartRemoveIconButtonStyle}">
                                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                        </Button>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <StackPanel
                                Padding="16,24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="6"
                                Visibility="{Binding IsCartEmpty, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    FontSize="24"
                                    Foreground="#A8B4C8"
                                    Glyph="&#xE7BF;" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                    Text="Tap a product or scan a barcode."
                                    TextAlignment="Center"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2" Spacing="10">
                        <Border Height="1" Background="{StaticResource PosPanelBorderBrush}" />
                        <TextBlock
                            FontSize="12.5"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource PosTextSecondaryBrush}"
                            Text="{Binding CartSubtotalText, Mode=OneWay}" />
                        <TextBlock
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource PosTextPrimaryBrush}"
                            Text="{Binding CartTotalText, Mode=OneWay}" />
                        <Button
                            Command="{Binding AddToTabCommand, Mode=OneWay}"
                            Content="Add to tab"
                            IsEnabled="{Binding CanAddToTab, Mode=OneWay}"
                            Style="{StaticResource AddDrinksPrimaryButtonStyle}"
                            UseSystemFocusVisuals="False" />
                        <Button
                            MinHeight="44"
                            Command="{Binding CancelCommand, Mode=OneWay}"
                            Content="Cancel"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNeg}, Mode=OneWay}"
                            Style="{StaticResource TabsHeaderActionButtonStyle}"
                            UseSystemFocusVisuals="False" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Busy overlay -->
        <Grid
            Grid.RowSpan="3"
            Background="{StaticResource PosBusyOverlayBrush}"
            Canvas.ZIndex="100"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, Mode=OneWay}">
            <ProgressRing
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="True" />
        </Grid>
    </Grid>
</UserControl>
