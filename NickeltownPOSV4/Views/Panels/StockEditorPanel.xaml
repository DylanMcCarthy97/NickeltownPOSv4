<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="NickeltownPOSV4.Views.Panels.StockEditorPanel"
    x:Name="RootGrid"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Foreground="{StaticResource PosTextPrimaryBrush}"
            Text="Stock &amp; categories" />

            <TextBlock
                Grid.Row="1"
                Margin="0,6,0,0"
                FontSize="12"
                Foreground="{StaticResource PosTextSecondaryBrush}"
                Text="{Binding PanelStatus, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />

        <Grid Grid.Row="2" Margin="0,10,0,0" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PosTextPrimaryBrush}"
                    Text="Filter by catalog" />
                <ComboBox
                    MinHeight="48"
                    HorizontalAlignment="Stretch"
                    FontSize="14"
                    ItemsSource="{Binding FilterChoices, Mode=OneWay}"
                    PlaceholderText="All"
                    SelectedItem="{Binding SelectedFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    FontSize="11"
                    Foreground="{StaticResource PosTextSecondaryBrush}"
                    Text="Bar / Pitstop / Shared and fixed sub-categories (V2). Full edits: Admin → Stock."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>

        <ScrollViewer
            Grid.Row="3"
            Margin="0,12,0,8"
            HorizontalAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Lines, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            Padding="10,10"
                            Background="{StaticResource PosSurfaceAltBrush}"
                            BorderBrush="{StaticResource PosBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <Grid RowSpacing="8" ColumnSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PosTextPrimaryBrush}"
                                    Text="{Binding DisplayName, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Grid.Row="1"
                                    MinHeight="48"
                                    Padding="12,10"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                    Text="{Binding CatalogDisplay, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                                <Grid Grid.Row="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        Grid.Column="0"
                                        MinWidth="72"
                                        MinHeight="48"
                                        Padding="10,8"
                                        HorizontalContentAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="#FFF8FAFF"
                                        BorderBrush="#FFD6E3F5"
                                        BorderThickness="1"
                                        Command="{Binding BeginQtyEntryCommand}"
                                        Content="{Binding QtyText, Mode=OneWay}"
                                        CornerRadius="8"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource TabsHeaderActionButtonStyle}"
                                        UseSystemFocusVisuals="False" />
                                    <CheckBox
                                        Grid.Column="2"
                                        MinWidth="88"
                                        VerticalAlignment="Center"
                                        Content="Track stock"
                                        FontSize="12"
                                        IsChecked="{Binding TrackStock, Mode=TwoWay}" />
                                    <Button
                                        Grid.Column="3"
                                        MinWidth="80"
                                        MinHeight="48"
                                        VerticalAlignment="Center"
                                        Command="{Binding SaveCommand, Mode=OneWay}"
                                        Content="Save"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource TabsHeaderActionButtonStyle}"
                                        UseSystemFocusVisuals="False" />
                                </Grid>
                                <TextBlock
                                    Grid.Row="3"
                                    FontSize="11"
                                    Foreground="{StaticResource PosTextSecondaryBrush}"
                                    Text="{Binding LineStatus, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button
            Grid.Row="4"
            MinHeight="48"
            HorizontalAlignment="Stretch"
            Command="{Binding CloseCommand, Mode=OneWay}"
            Content="Close"
            FontSize="15"
            FontWeight="SemiBold"
            Style="{StaticResource TabsHeaderActionButtonStyle}"
            UseSystemFocusVisuals="False" />
    </Grid>
</UserControl>
