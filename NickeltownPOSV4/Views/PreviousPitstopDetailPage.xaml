<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.PreviousPitstopDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="14,12,14,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsPageHeroStyle}">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource SettingsHeroTitleStyle}" Text="{Binding Title, Mode=OneWay}" />
                <TextBlock
                    Style="{StaticResource SettingsHeroSubtitleStyle}"
                    Text="{Binding SummaryText, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    FontSize="12"
                    Foreground="{StaticResource PosTextSecondaryBrush}"
                    Text="{Binding CashCardSplitText, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="Sales" />
                        <ItemsRepeater ItemsSource="{Binding Sales, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="12" Foreground="{StaticResource PosTextPrimaryBrush}">
                                        <Run Text="{Binding SoldAtText, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding PaymentMethod, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TotalText, Mode=OneWay}" />
                                        <Run Text="{Binding StaffText, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Item breakdown" />
                        <ItemsRepeater ItemsSource="{Binding ItemBreakdown, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Name, Mode=OneWay}" />
                                        <Run Text=" (" />
                                        <Run Text="{Binding Category, Mode=OneWay}" />
                                        <Run Text=") ×" />
                                        <Run Text="{Binding QtyText, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TotalText, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Payment breakdown" />
                        <ItemsRepeater ItemsSource="{Binding PaymentBreakdown, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="4" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding PaymentMethod, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{Binding TotalText, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Cash count" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource PosTextPrimaryBrush}"
                            Text="{Binding CashCountText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Notes" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource PosTextPrimaryBrush}"
                            Text="{Binding NotesText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCardStyle}">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Backups" />
                        <StackPanel Spacing="2">
                            <TextBlock FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="Before archive" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                Text="{Binding BackupBeforeText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock FontSize="11" Foreground="{StaticResource PosTextSecondaryBrush}" Text="After archive" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{StaticResource PosTextPrimaryBrush}"
                                Text="{Binding BackupAfterText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Style="{StaticResource SettingsCardStyle}"
                    Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                    <StackPanel Spacing="6">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Warnings / reconciliation" />
                        <ItemsControl ItemsSource="{Binding Warnings, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="12"
                                        Foreground="{StaticResource PosWarningAmberBrush}"
                                        Text="{Binding}"
                                        TextWrapping="WrapWholeWords" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <TextBlock
            Grid.Row="2"
            FontSize="12"
            Foreground="{StaticResource PosTextSecondaryBrush}"
            Text="{Binding StatusMessage, Mode=OneWay}" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10">
            <Button Command="{Binding ReprintCommand}" Content="Reprint / export report" Style="{StaticResource SettingsPrimaryButtonStyle}" />
            <Button
                Command="{Binding AddNoteCommand}"
                Content="Add note"
                Style="{StaticResource SettingsSecondaryButtonStyle}"
                Visibility="{Binding CanAddNote, Converter={StaticResource BoolToVis}, Mode=OneWay}" />
            <Button Command="{Binding BackCommand}" Content="Back" Style="{StaticResource SettingsSecondaryButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>
