<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NickeltownPOSV4.Views.PreviousPitstopItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:NickeltownPOSV4.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource PosCanvasBrush}"
    NavigationCacheMode="Disabled">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="14,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Style="{StaticResource SettingsHeroTitleStyle}"
            Text="{Binding Title, Mode=OneWay}" />

        <Border Grid.Row="1" Style="{StaticResource SettingsCardStyle}">
            <ItemsRepeater ItemsSource="{Binding Rows.CurrentPageItems, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="4" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="13" Foreground="{StaticResource PosTextPrimaryBrush}">
                            <Run Text="{Binding Name, Mode=OneWay}" />
                            <Run Text=" (" />
                            <Run Text="{Binding Category, Mode=OneWay}" />
                            <Run Text=") ×" />
                            <Run Text="{Binding QtyText, Mode=OneWay}" />
                            <Run Text=" " />
                            <Run Text="{Binding TotalText, Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="10">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="12"
                Text="{Binding Rows.RangeIndicator, Mode=OneWay}" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding Rows.PreviousPageCommand}" Content="Prev" Style="{StaticResource SettingsPagerButtonStyle}" />
                <Button Command="{Binding Rows.NextPageCommand}" Content="Next" Style="{StaticResource SettingsPagerButtonStyle}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="3" FontSize="12" Text="{Binding StatusMessage, Mode=OneWay}" />
        <Button Grid.Row="4" Command="{Binding BackCommand}" Content="Back" Style="{StaticResource SettingsSecondaryButtonStyle}" />
    </Grid>
</Page>
